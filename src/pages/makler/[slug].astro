---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import FooterCinematic from '../../components/sections/FooterCinematic.astro';
import MaklerProfilHero from '../../components/sections/MaklerProfilHero.astro';
import ProfilBio from '../../components/sections/ProfilBio.astro';
import ProfilSkills from '../../components/sections/ProfilSkills.astro';
import ProfilQualifikationen from '../../components/sections/ProfilQualifikationen.astro';
import ProfilBuerozeiten from '../../components/sections/ProfilBuerozeiten.astro';
import ProfilKontakt from '../../components/sections/ProfilKontakt.astro';
import ProfilRechtlicheHinweise from '../../components/sections/ProfilRechtlicheHinweise.astro';
import { loadProfilBySlug } from '../../lib/profil';
import { loadVermittler, type PublicVermittler } from '../../lib/vermittler';

const slug = Astro.params.slug ?? '';
const slugOk = /^[a-z0-9-]+$/.test(slug);

const profil = slugOk ? await loadProfilBySlug(slug) : null;

// Nur veröffentlichte Profile aktiver Makler sind sichtbar — sonst 404 (kein Leak).
let me: PublicVermittler | null = null;
if (profil && profil.published) {
  const vermittler = await loadVermittler();
  me = vermittler.find((v) => v.id === profil.uid) ?? null;
}

const notFound = !profil || !profil.published || !me;

if (notFound) {
  Astro.response.status = 404;
} else {
  // Live-Profile dürfen 1h vom CDN gecached werden (Muster aus makler-suche.astro).
  Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, stale-while-revalidate=86400');
}

// ---- nur relevant, wenn gefunden ----
const name = me?.name ?? '';
const telefon = profil?.kontakt?.telefon || me?.telefon || '';
const email = profil?.kontakt?.email || me?.email || '';
const website = profil?.kontakt?.website || '';
const siteOrigin = Astro.site?.origin ?? 'https://www.phoenix-maklerverbund.de';

const jsonLd =
  notFound || !profil || !me
    ? null
    : {
        '@context': 'https://schema.org',
        '@type': 'InsuranceAgent',
        name,
        description: profil.headline,
        worksFor: { '@type': 'InsuranceAgency', name: 'Phönix Maklerverbund' },
        ...(me.hasPhoto ? { image: `${siteOrigin}/api/vermittler-foto?uid=${profil.uid}` } : {}),
        ...(telefon ? { telephone: telefon } : {}),
        ...(email ? { email } : {}),
        ...(me.ort ? { areaServed: me.ort } : {}),
        url: new URL(Astro.url.pathname, siteOrigin).toString(),
      };
---

{notFound ? (
  <BaseLayout title="Profil nicht gefunden — Phönix Maklerverbund" noindex hideFooter>
    <section class="nf section">
      <div class="container-narrow">
        <span class="eyebrow">404</span>
        <h1 class="nf__title">Diese Maklerseite gibt es nicht.</h1>
        <p class="nf__text">Der Link ist möglicherweise veraltet oder das Profil ist nicht (mehr) öffentlich.</p>
        <div class="nf__actions">
          <a href="/makler-suche" class="btn btn-accent btn-lg">Zum Maklerfinder</a>
          <a href="/" class="btn btn-outline btn-lg">Zur Startseite</a>
        </div>
      </div>
    </section>
  </BaseLayout>
) : (
  <BaseLayout
    title={`${name} — Phönix Maklerverbund`}
    description={profil!.headline}
    hideFooter
  >
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <MaklerProfilHero
      name={name}
      headline={profil!.headline}
      ort={me!.ort}
      plz={me!.plz}
      uid={profil!.uid}
      hasPhoto={me!.hasPhoto}
      fokus={profil!.fokus}
      telefon={telefon}
    />
    <ProfilBio bio={profil!.bio} />
    <ProfilSkills skills={profil!.skills} />
    <ProfilQualifikationen qualifikationen={profil!.qualifikationen} />
    <ProfilBuerozeiten buerozeiten={profil!.buerozeiten} />
    <ProfilKontakt
      name={name}
      telefon={telefon}
      email={email}
      website={website}
      ort={me!.ort}
      plz={me!.plz}
    />
    <ProfilRechtlicheHinweise name={name} rechtliches={profil!.rechtliches} />
    <FooterCinematic />
  </BaseLayout>
)}

<style>
  .nf { min-height: 60vh; display: grid; align-items: center; }
  .nf__title { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 400; line-height: 1.05; margin: 1rem 0 0; }
  .nf__text { margin-top: 1rem; font-size: 1.1rem; color: var(--color-text-muted); max-width: 52ch; }
  .nf__actions { margin-top: 2rem; display: flex; gap: 1rem; flex-wrap: wrap; }
</style>
