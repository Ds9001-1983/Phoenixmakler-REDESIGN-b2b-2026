---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ErstinformationModal from '../../components/ErstinformationModal.astro';
import TeaserCard from '../../components/TeaserCard.astro';
import ProductBlock from '../../components/ProductBlock.astro';
import MaklerFindenCTA from '../../components/MaklerFindenCTA.astro';
import produkteData from '../../data/produkte.json';

type ProduktSlug = keyof typeof produkteData;

export async function getStaticPaths() {
  const { default: data } = await import('../../data/produkte.json');
  return Object.keys(data).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params as { slug: ProduktSlug };
const produkt = produkteData[slug];

if (!produkt) {
  return Astro.redirect('/kunde');
}
---

<BaseLayout title={produkt.title}>
  <ErstinformationModal />

  {/* HERO mit Bild */}
  <section class="hero-produkt">
    <div class="container hero-grid">
      <div class="hero-text" data-reveal>
        <span class="eyebrow">{produkt.eyebrow}</span>
        <h1 data-split>{produkt.title}</h1>
        <p class="lead" data-reveal data-reveal-delay="2">{produkt.intro}</p>
      </div>
      <figure class="hero-media" data-parallax-wrapper data-reveal data-reveal-delay="2">
        <img
          src={produkt.hero}
          alt=""
          width="1024"
          height="1024"
          loading="eager"
          fetchpriority="high"
          data-parallax="0.1"
        />
      </figure>
    </div>
  </section>

  {/* POTS */}
  {produkt.pots.length > 0 && (
    <section class="section bg-cream-warm">
      <div class="container">
        <div class="sec-head" data-reveal>
          <span class="eyebrow">Themen &amp; Tipps</span>
          <h2>Wissenswertes auf einen Blick.</h2>
        </div>
        <div class="pots-grid">
          {produkt.pots.map((pot, i) => (
            <div data-reveal data-reveal-delay={(i % 3) + 1}>
              <TeaserCard headline={pot.headline} url={pot.url} />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* PRODUKTE */}
  {produkt.produkte.length > 0 && (
    <section class="section bg-cream">
      <div class="container">
        <div class="sec-head" data-reveal>
          <span class="eyebrow">Empfohlene Produkte</span>
          <h2>Direkt <em>berechnen</em> und abschließen.</h2>
        </div>
        <div class="product-stack">
          {produkt.produkte.map((p, i) => (
            <div data-reveal data-reveal-delay={(i % 3) + 1}>
              <ProductBlock name={p.name} text={p.text} logo={p.logo} url={p.url} />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <MaklerFindenCTA />
</BaseLayout>

<style>
  .hero-produkt {
    padding-block: clamp(3rem, 6vw, 5rem) clamp(4rem, 7vw, 6rem);
    background: var(--color-cream);
    overflow: hidden;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }

  @media (max-width: 900px) { .hero-grid { grid-template-columns: 1fr; gap: 2rem; } }

  .hero-text h1 { max-width: 16ch; margin-bottom: 1.5rem; }

  .hero-media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4/5;
  }

  @media (max-width: 900px) { .hero-media { aspect-ratio: 4/3; } }

  .hero-media img {
    width: 100%;
    height: 115%;
    object-fit: cover;
    transform: translateY(-7%);
  }

  .sec-head {
    max-width: 640px;
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }

  .sec-head h2 em { font-style: italic; color: var(--color-accent-dark); font-weight: 400; }

  .pots-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  @media (min-width: 720px) {
    .pots-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .product-stack {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
</style>
