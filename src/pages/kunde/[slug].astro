---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ErstinformationModal from '../../components/ErstinformationModal.astro';
import TeaserCard from '../../components/TeaserCard.astro';
import ProductBlock from '../../components/ProductBlock.astro';
import MaklerFindenCTA from '../../components/MaklerFindenCTA.astro';
import produkteData from '../../data/produkte.json';

const heroImage: Record<string, string> = {
  altersvorsorge: '/images/hero/pot-altersvorsorge.png',
  einkommenssicherung: '/images/hero/pot-einkommen.png',
  zahnzusatzversicherung: '/images/hero/pot-zahn.png',
  krankenhauszusatzversicherung: '/images/hero/pot-zahn.png',
  haustier: '/images/hero/pot-haustier.png',
  'haus-wohnen': '/images/hero/pot-haus.png',
  vermoegensaufbau: '/images/hero/pot-vermoegen.png',
};

type ProduktSlug = keyof typeof produkteData;

export async function getStaticPaths() {
  const { default: data } = await import('../../data/produkte.json');
  return Object.keys(data).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params as { slug: ProduktSlug };
const produkt = produkteData[slug];

if (!produkt) {
  return Astro.redirect('/kunde');
}
---

<BaseLayout title={produkt.title}>
  <ErstinformationModal />

  <section class="hero-produkt">
    <div class="container">
      <span class="eyebrow">{produkt.eyebrow}</span>
      <h1>{produkt.title}</h1>
      <p class="lead">{produkt.intro}</p>
    </div>
  </section>

  <section class="hero-visual">
    <div class="container" data-reveal>
      <figure class="hero-visual-frame">
        <img src={heroImage[slug]} alt="" width="1920" height="1080" loading="eager" />
      </figure>
    </div>
  </section>

  {produkt.pots.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header" data-reveal>
          <span class="eyebrow">Themen & Tipps</span>
          <h2>Wissenswertes auf einen Blick</h2>
        </div>
        <div class="grid grid-3 pots-grid">
          {produkt.pots.map((pot, i) => (
            <div data-reveal data-reveal-delay={(i % 3) + 1}>
              <TeaserCard headline={pot.headline} url={pot.url} />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {produkt.produkte.length > 0 && (
    <section class="section section-bg">
      <div class="container">
        <div class="section-header" data-reveal>
          <span class="eyebrow">Empfohlene Produkte</span>
          <h2>Direkt berechnen und abschließen</h2>
        </div>
        <div class="product-stack">
          {produkt.produkte.map((p, i) => (
            <div data-reveal data-reveal-delay={(i % 3) + 1}>
              <ProductBlock name={p.name} text={p.text} logo={p.logo} url={p.url} />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <MaklerFindenCTA />
</BaseLayout>

<style>
  .hero-produkt {
    padding-block: clamp(3rem, 7vw, 5.5rem);
    background: linear-gradient(135deg, var(--color-primary-light) 0%, #ffffff 100%);
  }

  .hero-visual {
    padding-top: clamp(1rem, 3vw, 2rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .hero-visual-frame {
    overflow: hidden;
    border-radius: var(--radius-lg);
    aspect-ratio: 21/9;
    background: var(--color-bg-light);
    box-shadow: var(--shadow-md);
  }

  .hero-visual-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-produkt h1 {
    max-width: 20ch;
  }

  .hero-produkt .lead {
    margin-top: 1rem;
  }

  .section-header {
    max-width: 720px;
    margin-bottom: 2rem;
  }

  .pots-grid {
    gap: 1.5rem;
  }

  .product-stack {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
</style>
