---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ErstinformationModal from '../../components/ErstinformationModal.astro';
import CookieConsent from '../../components/CookieConsent.astro';
import TeaserCard from '../../components/TeaserCard.astro';
import ProductBlock from '../../components/ProductBlock.astro';
import MaklerFindenCTA from '../../components/MaklerFindenCTA.astro';
import produkteData from '../../data/produkte.json';

const heroImage: Record<string, string> = {
  altersvorsorge: '/images/hero/pot-altersvorsorge.png',
  einkommenssicherung: '/images/hero/pot-einkommen.png',
  zahnzusatzversicherung: '/images/hero/pot-zahn.png',
  krankenhauszusatzversicherung: '/images/hero/pot-zahn.png',
  haustier: '/images/hero/pot-haustier.png',
  'haus-wohnen': '/images/hero/pot-haus.png',
  vermoegensaufbau: '/images/hero/pot-vermoegen.png',
};

type ProduktSlug = keyof typeof produkteData;

export async function getStaticPaths() {
  const { default: data } = await import('../../data/produkte.json');
  return Object.keys(data).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params as { slug: ProduktSlug };
const produkt = produkteData[slug];

if (!produkt) {
  return Astro.redirect('/kunde');
}
---

<BaseLayout title={produkt.title}>
  <ErstinformationModal />
  <CookieConsent />

  {/* HERO asymmetric mit Pot-Bild */}
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text" data-reveal>
        <span class="badge">{produkt.eyebrow}</span>
        <h1>{produkt.title}</h1>
        <p class="lead">{produkt.intro}</p>
      </div>
      <div class="hero-visual" data-reveal data-reveal-delay="1">
        <div class="hero-visual-frame">
          <img src={heroImage[slug]} alt="" width="1024" height="1024" loading="eager" fetchpriority="high" />
        </div>
      </div>
    </div>
  </section>

  {produkt.pots.length > 0 && (
    <section class="section bg-soft">
      <div class="container">
        <div class="section-head" data-reveal>
          <span class="eyebrow">Themen &amp; Tipps</span>
          <h2>Wissenswertes auf einen Blick.</h2>
        </div>
        <div class="pots-grid">
          {produkt.pots.map((pot, i) => (
            <div data-reveal data-reveal-delay={(i % 3) + 1}>
              <TeaserCard headline={pot.headline} url={pot.url} />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {produkt.produkte.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-head" data-reveal>
          <span class="eyebrow">Empfohlene Produkte</span>
          <h2>Direkt berechnen<br />und abschließen.</h2>
        </div>
        <div class="product-stack">
          {produkt.produkte.map((p, i) => (
            <div data-reveal data-reveal-delay={(i % 3) + 1}>
              <ProductBlock name={p.name} text={p.text} logo={p.logo} url={p.url} />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <MaklerFindenCTA />
</BaseLayout>

<style>
  .hero {
    padding-block: clamp(2.5rem, 5vw, 4.5rem) clamp(3rem, 6vw, 5rem);
    background: var(--color-bg);
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }

  @media (max-width: 900px) { .hero-inner { grid-template-columns: 1fr; gap: 3rem; } }

  .hero-text h1 { max-width: 18ch; margin-block: 0 1.5rem; }

  .hero-visual-frame {
    aspect-ratio: 4/5;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--color-bg-soft);
    box-shadow: var(--shadow-lg);
  }

  @media (max-width: 900px) { .hero-visual-frame { aspect-ratio: 4/3; } }

  .hero-visual-frame img { width: 100%; height: 100%; object-fit: cover; }

  .section-head { max-width: 640px; margin-bottom: clamp(2rem, 5vw, 3.5rem); }

  .pots-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  @media (min-width: 720px) {
    .pots-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .product-stack {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
</style>
