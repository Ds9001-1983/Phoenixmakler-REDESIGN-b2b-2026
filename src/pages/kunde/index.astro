---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ErstinformationModal from '../../components/ErstinformationModal.astro';
import kacheln from '../../data/kunde-kacheln.json';
---

<BaseLayout title="Für Kunden – Phönix Maklerverbund">
  <ErstinformationModal />

  <section class="hero-kunde">
    <div class="container">
      <span class="eyebrow">Willkommen</span>
      <h1>Willkommen beim Phönix Maklerverbund</h1>
      <p class="lead">
        Der Phönix Maklerverbund unterstützt ungebundene Versicherungsmakler bei der Abwicklung
        ihrer Geschäfte. Ihr persönlicher Ansprechpartner ist Ihr Versicherungsmakler.
      </p>
    </div>
  </section>

  <section class="section section-search">
    <div class="container">
      <div class="search-card">
        <div>
          <span class="eyebrow">Maklersuche</span>
          <h2>Finden Sie Ihren Versicherungsmakler</h2>
          <p>Geben Sie Ihre PLZ oder den Namen ein – wir finden den passenden Ansprechpartner.</p>
        </div>
        <form class="search-form" action="/makler-suche" method="get" role="search">
          <label for="search-query" class="visually-hidden">PLZ oder Name</label>
          <input
            type="search"
            id="search-query"
            name="q"
            placeholder="PLZ oder Name eingeben"
            autocomplete="postal-code"
          />
          <button type="submit" class="btn btn-primary">Suchen →</button>
        </form>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header text-center">
        <span class="eyebrow">Leistungsbereiche</span>
        <h2>Informieren Sie sich über unsere Produkte</h2>
      </div>
      <div class="grid kachel-grid">
        {kacheln.map((k) => (
          <a href={`/kunde/${k.slug}`} class="kachel">
            <div class="kachel-icon" aria-hidden="true">{k.icon}</div>
            <h3>{k.title}</h3>
            <p>{k.text}</p>
            <span class="kachel-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-kunde {
    padding-block: clamp(3rem, 7vw, 5.5rem);
    background: linear-gradient(135deg, var(--color-primary-light) 0%, #ffffff 100%);
  }

  .section-search {
    padding-top: 0;
  }

  .search-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: center;
    background: #fff;
    padding: clamp(1.5rem, 4vw, 3rem);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-md);
    margin-top: -3rem;
  }

  @media (max-width: 768px) {
    .search-card {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  .search-form {
    display: flex;
    gap: 0.5rem;
  }

  .search-form input {
    flex: 1;
    min-height: var(--min-touch-target);
    padding: 0.75rem 1rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: 1rem;
  }

  .search-form input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-light);
  }

  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  .section-header {
    max-width: 720px;
    margin: 0 auto 3rem;
  }

  .kachel-grid {
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  .kachel {
    display: block;
    position: relative;
    padding: 2rem 1.75rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text);
    transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
  }

  .kachel:hover,
  .kachel:focus-visible {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary);
  }

  .kachel-icon {
    font-size: 2.25rem;
    margin-bottom: 1rem;
  }

  .kachel h3 {
    margin-bottom: 0.4rem;
    font-size: 1.15rem;
  }

  .kachel p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .kachel-arrow {
    position: absolute;
    right: 1.5rem;
    bottom: 1.5rem;
    font-size: 1.25rem;
    color: var(--color-primary-dark);
    transition: transform 150ms ease;
  }

  .kachel:hover .kachel-arrow {
    transform: translateX(4px);
  }
</style>
