---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ErstinformationModal from '../../components/ErstinformationModal.astro';
import kacheln from '../../data/kunde-kacheln.json';

const kachelImage: Record<string, string> = {
  altersvorsorge: '/images/hero/pot-altersvorsorge.png',
  einkommenssicherung: '/images/hero/pot-einkommen.png',
  zahnzusatzversicherung: '/images/hero/pot-zahn.png',
  krankenhauszusatzversicherung: '/images/hero/pot-zahn.png',
  haustier: '/images/hero/pot-haustier.png',
  'haus-wohnen': '/images/hero/pot-haus.png',
  vermoegensaufbau: '/images/hero/pot-vermoegen.png',
};
---

<BaseLayout title="Für Kunden – Phönix Maklerverbund">
  <ErstinformationModal />

  {/* HERO — Pflicht-Wortlaut aus Meeting 15.04.2026 */}
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text" data-reveal>
        <span class="badge">Für Kundinnen &amp; Kunden</span>
        <h1>
          Ihr Ansprechpartner<br />
          <span class="accent">ist Ihr Makler.</span>
        </h1>
        <p class="lead">
          Der Phönix Maklerverbund hilft Maklern bei der Abwicklung ihrer Geschäfte.
          Ansprechpartner für Sie als Kundin oder Kunde ist aber <strong>Ihr Versicherungsmakler</strong> —
          die Person, die Ihre Verträge betreut und Sie persönlich kennt.
        </p>
        <p class="lead" style="margin-top: 0.75rem;">
          <strong>Hier finden Sie Ihren Versicherungsmakler:</strong>
        </p>
      </div>
      <div class="hero-visual" data-reveal data-reveal-delay="1">
        <div class="hero-visual-frame">
          <img src="/images/audience/kunde.png" alt="Familie im Wohnzimmer" width="1024" height="1280" loading="eager" fetchpriority="high" />
        </div>
      </div>
    </div>
  </section>

  {/* SUCH-BAND */}
  <section class="search-band">
    <div class="container">
      <div class="search-card" data-reveal>
        <div>
          <span class="eyebrow">Maklersuche</span>
          <h2>Finden Sie Ihren Makler.</h2>
          <p>Geben Sie Ihre PLZ oder den Namen ein — wir finden den passenden Ansprechpartner.</p>
        </div>
        <form class="search-form" action="/makler-suche" method="get" role="search">
          <label for="search-query" class="visually-hidden">PLZ oder Name</label>
          <input
            type="search"
            id="search-query"
            name="q"
            placeholder="PLZ oder Name eingeben"
            autocomplete="postal-code"
          />
          <button type="submit" class="btn btn-primary">Suchen →</button>
        </form>
      </div>
    </div>
  </section>

  {/* LEISTUNGEN Bento */}
  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Leistungsbereiche</span>
        <h2>Sieben Bereiche.<br />Eine Beratung auf Augenhöhe.</h2>
      </div>

      <div class="leistungen-grid">
        {kacheln.map((k, i) => (
          <a href={`/kunde/${k.slug}`} class="leistung-card" data-reveal data-reveal-delay={(i % 3) + 1}>
            <div class="leistung-media">
              <img src={kachelImage[k.slug]} alt="" loading="lazy" />
            </div>
            <div class="leistung-body">
              <h3>{k.title}</h3>
              <p>{k.text}</p>
              <span class="leistung-arrow">Ansehen →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* HERO */
  .hero {
    padding-block: clamp(2.5rem, 5vw, 4.5rem) clamp(3rem, 6vw, 5rem);
    background: var(--color-bg);
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }

  @media (max-width: 900px) { .hero-inner { grid-template-columns: 1fr; gap: 3rem; } }

  .hero-text h1 .accent { color: var(--color-primary); }
  .hero-text .lead { margin-top: 1.5rem; }

  .hero-visual-frame {
    aspect-ratio: 4/5;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--color-bg-soft);
    box-shadow: var(--shadow-lg);
  }

  @media (max-width: 900px) { .hero-visual-frame { aspect-ratio: 4/3; } }

  .hero-visual-frame img { width: 100%; height: 100%; object-fit: cover; }

  /* Search Band */
  .search-band {
    background: var(--color-ink);
    padding-block: clamp(3rem, 5vw, 4rem);
  }

  .search-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
  }

  @media (max-width: 800px) { .search-card { grid-template-columns: 1fr; } }

  .search-card .eyebrow { color: var(--color-accent); }
  .search-card .eyebrow::before { background: rgba(255,255,255,0.4); }
  .search-card h2 { color: #fff; margin-bottom: 0.5rem; }
  .search-card p { color: rgba(255,255,255,0.7); max-width: 42ch; }

  .search-form {
    display: flex;
    gap: 0.5rem;
  }

  .search-form input {
    flex: 1;
    min-height: 52px;
    padding: 0.9rem 1.25rem;
    background: rgba(255,255,255,0.05);
    border: 1.5px solid rgba(255,255,255,0.2);
    border-radius: 999px;
    font-size: 1rem;
    color: #fff;
  }

  .search-form input::placeholder { color: rgba(255,255,255,0.5); }

  .search-form input:focus {
    outline: none;
    border-color: var(--color-accent);
    background: rgba(255,255,255,0.08);
  }

  .search-form .btn { min-height: 52px; background: var(--color-accent); color: var(--color-ink); }
  .search-form .btn:hover { background: var(--color-accent-bright); }

  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  /* Section Head */
  .section-head { max-width: 680px; margin-bottom: clamp(2.5rem, 5vw, 4rem); }

  /* Leistungen */
  .leistungen-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .leistung-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    color: var(--color-ink);
    transition: border-color 260ms ease, transform 260ms var(--ease-out), box-shadow 260ms ease;
  }

  .leistung-card:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .leistung-media {
    aspect-ratio: 16/10;
    overflow: hidden;
    background: var(--color-bg-soft);
  }

  .leistung-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 700ms var(--ease-out);
  }

  .leistung-card:hover .leistung-media img { transform: scale(1.04); }

  .leistung-body {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .leistung-card h3 { font-size: 1.2rem; }
  .leistung-card p { color: var(--color-text-muted); font-size: 0.95rem; }

  .leistung-arrow {
    margin-top: 1rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
    transition: transform 240ms var(--ease-out);
  }

  .leistung-card:hover .leistung-arrow { transform: translateX(4px); }
</style>
