---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ErstinformationModal from '../../components/ErstinformationModal.astro';
import CookieConsent from '../../components/CookieConsent.astro';
import InsurerMarquee from '../../components/sections/InsurerMarquee.astro';
import FooterCinematic from '../../components/sections/FooterCinematic.astro';

// PW External-Login-Link für Interessenten (Stammdaten → External Login → "Link für Interessenten").
// Sobald der finale Link aus PW vorliegt, hier eintragen — bis dahin Fallback auf /kontakt.
const APP_LINK = '/kontakt?betreff=app-zugang';

const wege = [
  {
    num: '01',
    title: 'Ich bin Kunde',
    body: 'Sie sind bereits über einen unserer Makler bei uns betreut und möchten Zugang zur App? Wir richten Ihnen den Zugang ein.',
    href: '/kontakt?betreff=zugang',
  },
  {
    num: '02',
    title: 'Ich möchte Kunde werden',
    body: 'Sie suchen einen Makler aus dem Phönix-Netzwerk? Sprechen Sie uns an — wir bringen Sie mit dem passenden Ansprechpartner in Ihrer Region zusammen.',
    href: '/kontakt?betreff=neukunde',
  },
  {
    num: '03',
    title: 'Ich bin Firmenkunde',
    body: 'Geschäftliche Versicherungen, Mitarbeiter-Benefits oder betriebliche Altersvorsorge: Für Unternehmen haben wir eigene Ansprechpartner.',
    href: '/kontakt?betreff=firmenkunde',
  },
];
---

<BaseLayout
  title="Für Kunden – Phönix Maklerverbund"
  description="Ihr Ansprechpartner ist Ihr Versicherungsmakler. Hier finden Sie Ihren Makler aus dem Phönix-Netzwerk."
  hideFooter={true}
>
  <ErstinformationModal />
  <CookieConsent />

  {/* HERO — Meeting-Wortlaut + integrierte Maklersuche */}
  <section class="kd-hero">
    <div class="kd-hero__container">
      <div class="kd-hero__text">
        <span class="kd-hero__caption">Für Kundinnen &amp; Kunden</span>
        <h1 class="kd-hero__title" data-split="words" data-split-trigger="load" data-split-stagger="0.07" data-split-delay="0.2">
          Ihr Ansprechpartner<br/>
          <em>ist Ihr Makler.</em>
        </h1>
        <p class="kd-hero__lead" data-reveal data-reveal-delay="3">
          Der Phönix Maklerverbund unterstützt Makler bei der Abwicklung ihrer Geschäfte.
          Für Sie als Kundin oder Kunde ist jedoch <strong>Ihr Versicherungsmakler</strong> der
          richtige Ansprechpartner – also die Person, die Ihre Verträge betreut und Sie
          persönlich kennt.
        </p>

        <div class="kd-hero__search" data-reveal data-reveal-delay="4">
          <p class="kd-hero__search-label">Hier finden Sie Ihren Versicherungsmakler:</p>
          <form class="kd-hero__form" action="/makler-suche" method="get" role="search">
            <label for="kd-search" class="visually-hidden">PLZ oder Name</label>
            <input
              type="search"
              id="kd-search"
              name="q"
              placeholder="PLZ oder Name eingeben"
              autocomplete="postal-code"
              required
            />
            <button type="submit" class="btn btn-primary">
              Suchen
              <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true"><path d="M1 5h11M9 1l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </form>
          <p class="kd-hero__hint">
            Über 120 Maklerinnen und Makler bundesweit · Direkter Kontakt zu Ihrem persönlichen Ansprechpartner
          </p>
        </div>
      </div>
      <div class="kd-hero__visual" data-reveal data-reveal-delay="1">
        <div class="kd-hero__media">
          <picture>
            <source srcset="/images/audience/kunde.webp" type="image/webp" />
            <img src="/images/audience/kunde.jpg" alt="Familie im Wohnzimmer" width="1024" height="1280" loading="eager" fetchpriority="high" />
          </picture>
        </div>
      </div>
    </div>
  </section>

  {/* APP + WEGE */}
  <section class="kd-wege">
    <div class="kd-wege__container">
      <div class="kd-wege__app" data-reveal>
        <span class="kd-wege__caption">Phönix-App</span>
        <h2 class="kd-wege__title">
          Die App zum<br/>
          <em>Phönix Maklerverbund.</em>
        </h2>
        <p class="kd-wege__lead">
          Verträge, Dokumente und Ansprechpartner immer dabei. Sicher,
          übersichtlich und ohne Papierkram.
        </p>
        <a href={APP_LINK} class="btn btn-primary btn-lg" data-magnetic data-cursor-label="App-Zugang anfragen">
          App-Zugang anfragen
          <svg width="18" height="14" viewBox="0 0 18 14" fill="none" aria-hidden="true"><path d="M1 7h15M12 1l5 6-5 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <div class="kd-wege__grid">
        {wege.map((w, i) => (
          <a href={w.href} class="kd-weg" data-reveal data-reveal-delay={i + 1} data-cursor-label="Sprechen Sie uns an">
            <span class="kd-weg__num">{w.num}</span>
            <h3 class="kd-weg__title">{w.title}</h3>
            <p class="kd-weg__body">{w.body}</p>
            <span class="kd-weg__arrow" aria-hidden="true">
              <svg width="20" height="14" viewBox="0 0 20 14" fill="none"><path d="M1 7h17M14 1l5 6-5 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <InsurerMarquee />
  <FooterCinematic />
</BaseLayout>

<style>
  /* HERO */
  .kd-hero {
    padding-block: clamp(5rem, 10vh, 8rem) clamp(4rem, 8vh, 6rem);
    background: var(--color-bg);
  }
  .kd-hero__container {
    max-width: var(--content-max-width);
    margin-inline: auto;
    padding-inline: var(--padding-x);
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }
  .kd-hero__text { max-width: 620px; }
  .kd-hero__caption {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
    margin-bottom: 1.5rem;
  }
  .kd-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 6.5vw, 5.5rem);
    font-weight: 400;
    line-height: 0.96;
    letter-spacing: -0.035em;
    color: var(--color-ink);
    margin: 0;
    font-variation-settings: 'opsz' 144, 'SOFT' 100;
  }
  .kd-hero__title em {
    font-style: italic;
    font-weight: 300;
    color: var(--color-accent);
  }
  .kd-hero__lead {
    margin-top: 1.75rem;
    font-size: clamp(1rem, 1.3vw, 1.12rem);
    line-height: 1.6;
    color: var(--color-text);
    max-width: 58ch;
  }
  .kd-hero__lead strong { color: var(--color-ink); font-weight: 500; }

  .kd-hero__search {
    margin-top: 2.25rem;
    padding: 1.5rem;
    background: var(--color-primary-dark);
    color: #fff;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }
  .kd-hero__search-label {
    font-family: var(--font-body);
    font-size: 0.98rem;
    font-weight: 500;
    color: #fff;
    margin: 0 0 0.9rem;
  }
  .kd-hero__form {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .kd-hero__form input {
    flex: 1;
    min-height: 52px;
    padding: 0.9rem 1.25rem;
    background: rgba(255,255,255,0.06);
    border: 1.5px solid rgba(255,255,255,0.22);
    border-radius: 999px;
    font-size: 1rem;
    color: #fff;
  }
  .kd-hero__form input::placeholder { color: rgba(255,255,255,0.55); }
  .kd-hero__form input:focus {
    outline: none;
    border-color: var(--color-accent);
    background: rgba(255,255,255,0.1);
  }
  .kd-hero__form .btn {
    min-height: 52px;
    padding-inline: 1.5rem;
    gap: 0.5rem;
    background: var(--color-accent);
    color: var(--color-ink);
    border-color: var(--color-accent);
  }
  .kd-hero__form .btn:hover {
    background: var(--color-accent-bright);
    border-color: var(--color-accent-bright);
  }
  .kd-hero__hint {
    font-size: 0.82rem;
    line-height: 1.5;
    color: rgba(255,255,255,0.55);
    margin: 0;
  }

  .kd-hero__visual { position: relative; }
  .kd-hero__media {
    aspect-ratio: 4/5;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--color-bg-soft);
    box-shadow: var(--shadow-lg);
  }
  .kd-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 960px) {
    .kd-hero__container { grid-template-columns: 1fr; gap: 3rem; }
    .kd-hero__media { aspect-ratio: 4/3; }
  }
  @media (max-width: 520px) {
    .kd-hero__form { flex-direction: column; }
    .kd-hero__form .btn { width: 100%; }
  }

  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  /* APP + WEGE */
  .kd-wege {
    padding-block: clamp(5rem, 10vh, 8rem);
    background: var(--color-bg-warm);
  }
  .kd-wege__container {
    max-width: var(--content-max-width);
    margin-inline: auto;
    padding-inline: var(--padding-x);
  }
  .kd-wege__app {
    max-width: 58ch;
    margin-bottom: clamp(3rem, 6vh, 4.5rem);
  }
  .kd-wege__caption {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
    margin-bottom: 1rem;
  }
  .kd-wege__title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin: 0 0 1.25rem;
    font-variation-settings: 'opsz' 144, 'SOFT' 75;
  }
  .kd-wege__title em {
    font-style: italic;
    font-weight: 300;
    color: var(--color-accent);
  }
  .kd-wege__lead {
    font-size: 1rem;
    line-height: 1.55;
    color: var(--color-text-muted);
    max-width: 52ch;
    margin: 0 0 2rem;
  }

  .kd-wege__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.25rem, 2.5vw, 1.75rem);
  }

  .kd-weg {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 2rem 1.75rem 1.85rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-ink);
    text-decoration: none;
    transition: border-color 280ms ease, transform 320ms var(--ease-out), box-shadow 280ms ease;
  }
  .kd-weg:hover {
    border-color: var(--color-accent);
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .kd-weg__num {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    color: var(--color-accent-dark);
  }
  .kd-weg__title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2vw, 1.65rem);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    margin: 0;
  }
  .kd-weg__body {
    font-size: 0.96rem;
    line-height: 1.55;
    color: var(--color-text-muted);
    margin: 0;
  }
  .kd-weg__arrow {
    margin-top: auto;
    color: var(--color-accent-dark);
    transition: transform 300ms ease, color 200ms ease;
    display: inline-block;
    padding-top: 0.5rem;
  }
  .kd-weg:hover .kd-weg__arrow {
    transform: translateX(4px);
    color: var(--color-accent);
  }

  @media (max-width: 900px) {
    .kd-wege__grid { grid-template-columns: 1fr; }
  }
</style>
