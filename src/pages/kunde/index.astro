---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ErstinformationModal from '../../components/ErstinformationModal.astro';
import kacheln from '../../data/kunde-kacheln.json';

const kachelImage: Record<string, string> = {
  altersvorsorge: '/images/hero/pot-altersvorsorge.png',
  einkommenssicherung: '/images/hero/pot-einkommen.png',
  zahnzusatzversicherung: '/images/hero/pot-zahn.png',
  krankenhauszusatzversicherung: '/images/hero/pot-zahn.png',
  haustier: '/images/hero/pot-haustier.png',
  'haus-wohnen': '/images/hero/pot-haus.png',
  vermoegensaufbau: '/images/hero/pot-vermoegen.png',
};
---

<BaseLayout title="Für Kunden – Phönix Maklerverbund">
  <ErstinformationModal />

  <section class="hero-kunde">
    <div class="container">
      <span class="eyebrow">Willkommen</span>
      <h1>Willkommen beim Phönix Maklerverbund</h1>
      <p class="lead">
        Der Phönix Maklerverbund unterstützt ungebundene Versicherungsmakler bei der Abwicklung
        ihrer Geschäfte. Ihr persönlicher Ansprechpartner ist Ihr Versicherungsmakler.
      </p>
    </div>
  </section>

  <section class="hero-visual">
    <div class="container" data-reveal>
      <figure class="hero-visual-frame">
        <img src="/images/hero/hero-kunde.png" alt="Warmes Wohnzimmer" width="1920" height="1080" loading="eager" />
      </figure>
    </div>
  </section>

  <section class="section section-search">
    <div class="container">
      <div class="search-card" data-reveal>
        <div>
          <span class="eyebrow">Maklersuche</span>
          <h2>Finden Sie Ihren Versicherungsmakler</h2>
          <p>Geben Sie Ihre PLZ oder den Namen ein – wir finden den passenden Ansprechpartner.</p>
        </div>
        <form class="search-form" action="/makler-suche" method="get" role="search">
          <label for="search-query" class="visually-hidden">PLZ oder Name</label>
          <input
            type="search"
            id="search-query"
            name="q"
            placeholder="PLZ oder Name eingeben"
            autocomplete="postal-code"
          />
          <button type="submit" class="btn btn-primary">Suchen →</button>
        </form>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header text-center">
        <span class="eyebrow">Leistungsbereiche</span>
        <h2>Informieren Sie sich über unsere Produkte</h2>
      </div>
      <div class="grid kachel-grid">
        {kacheln.map((k, i) => (
          <a href={`/kunde/${k.slug}`} class="kachel" data-reveal data-reveal-delay={(i % 3) + 1}>
            <div class="kachel-image">
              <img src={kachelImage[k.slug]} alt="" loading="lazy" />
            </div>
            <div class="kachel-body">
              <h3>{k.title}</h3>
              <p>{k.text}</p>
              <span class="kachel-arrow" aria-hidden="true">Mehr erfahren →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-kunde {
    padding-block: clamp(3rem, 7vw, 5.5rem);
    background: linear-gradient(135deg, var(--color-primary-light) 0%, #ffffff 100%);
  }

  .hero-visual {
    padding-top: clamp(1rem, 3vw, 2rem);
    padding-bottom: clamp(2rem, 4vw, 3rem);
  }

  .hero-visual-frame {
    overflow: hidden;
    border-radius: var(--radius-lg);
    aspect-ratio: 21/9;
    background: var(--color-bg-light);
    box-shadow: var(--shadow-md);
  }

  .hero-visual-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .section-search {
    padding-top: 0;
  }

  .search-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: center;
    background: #fff;
    padding: clamp(1.5rem, 4vw, 3rem);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-md);
  }

  @media (max-width: 768px) {
    .search-card {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  .search-form {
    display: flex;
    gap: 0.5rem;
  }

  .search-form input {
    flex: 1;
    min-height: var(--min-touch-target);
    padding: 0.75rem 1rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: 1rem;
  }

  .search-form input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-light);
  }

  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  .section-header {
    max-width: 720px;
    margin: 0 auto 3rem;
  }

  .kachel-grid {
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  .kachel {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    color: var(--color-text);
    transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
  }

  .kachel:hover,
  .kachel:focus-visible {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary);
  }

  .kachel-image {
    aspect-ratio: 16/10;
    overflow: hidden;
    background: var(--color-bg-light);
  }

  .kachel-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 700ms var(--ease-out);
  }

  .kachel:hover .kachel-image img {
    transform: scale(1.04);
  }

  .kachel-body {
    padding: 1.5rem 1.75rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .kachel h3 {
    font-size: 1.15rem;
    margin-bottom: 0.25rem;
  }

  .kachel p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .kachel-arrow {
    margin-top: 0.75rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
    transition: transform 200ms ease;
  }

  .kachel:hover .kachel-arrow { transform: translateX(4px); }
</style>
