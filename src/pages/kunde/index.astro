---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ErstinformationModal from '../../components/ErstinformationModal.astro';
import kacheln from '../../data/kunde-kacheln.json';

const kachelImage: Record<string, string> = {
  altersvorsorge: '/images/hero/pot-altersvorsorge.png',
  einkommenssicherung: '/images/hero/pot-einkommen.png',
  zahnzusatzversicherung: '/images/hero/pot-zahn.png',
  krankenhauszusatzversicherung: '/images/hero/pot-zahn.png',
  haustier: '/images/hero/pot-haustier.png',
  'haus-wohnen': '/images/hero/pot-haus.png',
  vermoegensaufbau: '/images/hero/pot-vermoegen.png',
};
---

<BaseLayout title="Für Kunden – Phönix Maklerverbund">
  <ErstinformationModal />

  {/* HERO */}
  <section class="hero-kunde">
    <div class="container hero-grid">
      <div class="hero-text" data-reveal>
        <span class="eyebrow">Für Kundinnen &amp; Kunden</span>
        <h1 data-split>
          Ihr persönlicher Makler — <em>unser</em> Netzwerk.
        </h1>
        <p class="lead" data-reveal data-reveal-delay="2">
          Der Phönix Maklerverbund unterstützt ungebundene Versicherungsmakler bei der Abwicklung
          ihrer Geschäfte. Ihr persönlicher Ansprechpartner bleibt Ihr Versicherungsmakler.
        </p>
      </div>
      <figure class="hero-media" data-parallax-wrapper data-reveal data-reveal-delay="2">
        <img
          src="/images/hero/hero-kunde.png"
          alt="Warmes Wohnzimmer – Geborgenheit"
          width="1024"
          height="1024"
          loading="eager"
          fetchpriority="high"
          data-parallax="0.1"
        />
      </figure>
    </div>
  </section>

  {/* SUCH-BAND */}
  <section class="section-sm search-band">
    <div class="container">
      <div class="search-wrap" data-reveal>
        <div>
          <span class="eyebrow">Maklersuche</span>
          <h2>Finden Sie Ihren Versicherungsmakler.</h2>
        </div>
        <form class="search-form" action="/makler-suche" method="get" role="search">
          <label for="search-query" class="visually-hidden">PLZ oder Name</label>
          <input
            type="search"
            id="search-query"
            name="q"
            placeholder="PLZ oder Name eingeben"
            autocomplete="postal-code"
          />
          <button type="submit" class="btn btn-primary">Suchen →</button>
        </form>
      </div>
    </div>
  </section>

  {/* LEISTUNGSBEREICHE */}
  <section class="section bg-cream">
    <div class="container">
      <div class="sec-head" data-reveal>
        <span class="eyebrow">Leistungsbereiche</span>
        <h2 data-split>
          Sieben <em>Bereiche</em>, in denen wir Sie begleiten.
        </h2>
      </div>
      <ul class="kachel-list">
        {kacheln.map((k, i) => (
          <li data-reveal data-reveal-delay={(i % 3) + 1}>
            <a href={`/kunde/${k.slug}`} class="kachel">
              <div class="kachel-media">
                <img src={kachelImage[k.slug]} alt="" loading="lazy" />
              </div>
              <div class="kachel-body">
                <span class="kachel-num">{String(i + 1).padStart(2, '0')}</span>
                <h3>{k.title}</h3>
                <p>{k.text}</p>
                <span class="kachel-arrow">Ansehen →</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero-kunde {
    padding-block: clamp(3rem, 6vw, 5rem) clamp(4rem, 7vw, 6rem);
    background: var(--color-cream);
    overflow: hidden;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }

  @media (max-width: 900px) { .hero-grid { grid-template-columns: 1fr; gap: 2.5rem; } }

  .hero-text h1 em { font-style: italic; color: var(--color-accent-dark); font-weight: 400; }

  .hero-media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4/5;
  }

  @media (max-width: 900px) { .hero-media { aspect-ratio: 4/3; } }

  .hero-media img {
    width: 100%;
    height: 115%;
    object-fit: cover;
    transform: translateY(-7%);
  }

  /* Search band */
  .search-band {
    background: var(--color-cream-warm);
    border-block: 1px solid var(--color-border);
  }

  .search-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (max-width: 800px) { .search-wrap { grid-template-columns: 1fr; gap: 1.5rem; } }

  .search-form {
    display: flex;
    gap: 0.5rem;
  }

  .search-form input {
    flex: 1;
    min-height: var(--min-touch-target);
    padding: 0.9rem 1.25rem;
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: 0;
    font-size: 1rem;
  }

  .search-form input:focus {
    outline: none;
    border-color: var(--color-primary);
    background: #fff;
  }

  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  /* Section Head */
  .sec-head {
    max-width: 640px;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .sec-head h2 em { font-style: italic; color: var(--color-accent-dark); font-weight: 400; }

  /* Kacheln als editorial list */
  .kachel-list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem 1.5rem;
  }

  .kachel {
    display: flex;
    flex-direction: column;
    color: var(--color-dark);
    height: 100%;
  }

  .kachel-media {
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--color-cream-warm);
    margin-bottom: 1.5rem;
  }

  .kachel-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 900ms var(--ease-out);
  }

  .kachel:hover .kachel-media img { transform: scale(1.04); }

  .kachel-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-inline: 0.25rem;
  }

  .kachel-num {
    font-family: var(--font-display);
    font-size: 0.9rem;
    color: var(--color-accent-dark);
    font-weight: 500;
    letter-spacing: 0.08em;
    margin-bottom: 0.25rem;
  }

  .kachel h3 {
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    margin-bottom: 0.4rem;
    transition: color 200ms ease;
  }

  .kachel:hover h3 { color: var(--color-primary); }

  .kachel p {
    color: var(--color-text-muted);
    font-size: 0.98rem;
    margin-bottom: 0.75rem;
  }

  .kachel-arrow {
    font-family: var(--font-body);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--color-primary);
    letter-spacing: 0.02em;
    border-bottom: 1px solid transparent;
    align-self: flex-start;
    transition: border-color 220ms ease, transform 320ms var(--ease-out);
    padding-bottom: 2px;
  }

  .kachel:hover .kachel-arrow {
    border-bottom-color: var(--color-primary);
    transform: translateX(4px);
  }
</style>
