---
import BaseLayout from '../layouts/BaseLayout.astro';
import makler from '../data/makler.json';

const q = Astro.url.searchParams.get('q') ?? '';
---

<BaseLayout title="Maklerfinder – Phönix Maklerverbund">
  <section class="hero-suche">
    <div class="container" data-reveal>
      <span class="eyebrow">Maklerfinder</span>
      <h1>Finden Sie <span class="accent">Ihren</span><br />Versicherungsmakler.</h1>
      <p class="lead">
        Alle Partner des Phönix Maklerverbunds auf einen Blick. Suchen Sie nach Ort,
        PLZ oder Namen und nehmen Sie direkt Kontakt auf.
      </p>
      <form class="search-bar" role="search" method="get">
        <label for="q" class="visually-hidden">PLZ, Ort oder Name</label>
        <input
          id="q"
          name="q"
          type="search"
          placeholder="PLZ, Ort oder Name eingeben"
          value={q}
          data-search-input
        />
        <button type="submit" class="btn btn-primary">Suchen →</button>
      </form>
    </div>
  </section>

  <section class="section bg-soft">
    <div class="container">
      <p class="results-hint" data-reveal>
        Zeigt aktuell {makler.length} Phönix-Partner. Die vollständige Liste mit über 120
        Vermittlern wird nach Anbindung des CRM-Systems dynamisch geladen.
      </p>
      <ul class="makler-list" data-makler-list>
        {makler.map((m, i) => (
          <li
            class="makler-card"
            data-name={m.name.toLowerCase()}
            data-ort={m.ort.toLowerCase()}
            data-plz={m.plz}
            data-reveal
            data-reveal-delay={(i % 4) + 1}
          >
            <div class="makler-avatar" aria-hidden="true">
              {m.name.split(' ').map((n) => n[0]).slice(0, 2).join('').toUpperCase()}
            </div>
            <div class="makler-info">
              <h3>{m.name}</h3>
              {m.ort !== '—' && <p class="makler-ort">{m.plz} {m.ort}</p>}
              <div class="makler-actions">
                <a href={`tel:${m.telefon.replace(/[\s\-]/g, '')}`} class="makler-link">Anrufen</a>
                <span class="sep" aria-hidden="true">·</span>
                <a href={`mailto:${m.email}`} class="makler-link">E-Mail</a>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-suche {
    padding-block: clamp(3rem, 6vw, 5rem);
    background: var(--color-bg);
  }

  .hero-suche h1 { max-width: 22ch; }
  .hero-suche h1 .accent { color: var(--color-primary); }
  .hero-suche .lead { margin-block: 1.5rem 2.5rem; }

  .search-bar {
    display: flex;
    gap: 0.5rem;
    max-width: 560px;
  }

  .search-bar input {
    flex: 1;
    min-height: 52px;
    padding: 0.9rem 1.25rem;
    background: #fff;
    border: 1.5px solid var(--color-border);
    border-radius: 999px;
    font-size: 1rem;
  }

  .search-bar input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.12);
  }

  .search-bar .btn { min-height: 52px; }

  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  .results-hint {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
    max-width: 64ch;
  }

  .makler-list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
  }

  .makler-card {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 1.25rem;
    align-items: center;
    padding: 1.5rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: border-color 260ms ease, background-color 280ms ease, transform 220ms var(--ease-out);
  }

  .makler-card[hidden] { display: none; }

  .makler-card:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }

  .makler-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--color-ink);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: 0.02em;
  }

  .makler-info h3 {
    font-size: 1.1rem;
    margin-bottom: 0.2rem;
    font-weight: 600;
  }

  .makler-ort {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .makler-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .makler-link {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--color-primary);
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
    transition: border-color 220ms ease;
  }

  .makler-link:hover { border-bottom-color: var(--color-primary); }

  .sep { color: var(--color-border-strong); }
</style>

<script>
  // TODO(Phase 2): Liste aus PW-API laden, sobald CRM-Zugang vorliegt.
  const input = document.querySelector<HTMLInputElement>('[data-search-input]');
  const list = document.querySelectorAll<HTMLLIElement>('.makler-card');

  const applyFilter = (q: string) => {
    const term = q.trim().toLowerCase();
    list.forEach((item) => {
      const haystack = [item.dataset.name, item.dataset.ort, item.dataset.plz].join(' ');
      item.hidden = term.length > 0 && !haystack.includes(term);
    });
  };

  const urlQ = new URLSearchParams(window.location.search).get('q');
  if (input && urlQ) {
    input.value = urlQ;
    applyFilter(urlQ);
  }

  input?.addEventListener('input', (e) => {
    applyFilter((e.target as HTMLInputElement).value);
  });
</script>
