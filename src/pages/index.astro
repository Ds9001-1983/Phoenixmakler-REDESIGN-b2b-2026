---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCinematic from '../components/sections/HeroCinematic.astro';
import HookStatement from '../components/sections/HookStatement.astro';
import AudienceSplit from '../components/sections/AudienceSplit.astro';
import ProductShowcase from '../components/sections/ProductShowcase.astro';
import ProcessPin from '../components/sections/ProcessPin.astro';
import TestimonialsMarquee from '../components/sections/TestimonialsMarquee.astro';
import InsurerMarquee from '../components/sections/InsurerMarquee.astro';
import SplitCTA from '../components/sections/SplitCTA.astro';
import FooterCinematic from '../components/sections/FooterCinematic.astro';
---

<BaseLayout
  title="Phönix Maklerverbund – Versichern ist Vertrauenssache"
  description="Ungebundener Versicherungsmakler-Verbund. Echte Beratung für Privatkunden und echte Partnerschaft für Makler. Inhabergeführt seit 2012."
  hideFooter={true}
>
  <HeroCinematic />
  <HookStatement />
  <AudienceSplit />
  <ProductShowcase />
  <ProcessPin />
  <TestimonialsMarquee />
  <InsurerMarquee />
  <SplitCTA />
  <FooterCinematic />
</BaseLayout>
