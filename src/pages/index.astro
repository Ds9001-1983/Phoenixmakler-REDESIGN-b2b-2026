---
import BaseLayout from '../layouts/BaseLayout.astro';

const vorteile = [
  {
    icon: '📈',
    title: 'Seit 2012',
    text: 'Inhabergeführt und 100% ungebunden von Kapitalgebern oder Versicherungsgesellschaften.',
  },
  {
    icon: '🤝',
    title: '120+ Vermittler',
    text: 'Ein starkes, deutschlandweites Netzwerk aus spezialisierten Versicherungsmaklern.',
  },
  {
    icon: '⚡',
    title: 'Exklusive Courtagen',
    text: 'Besondere Vereinbarungen mit Versicherern und ein transparentes Courtagemodell.',
  },
  {
    icon: '💻',
    title: 'MVP kostenlos',
    text: 'Professional Works – professionelles Maklerverwaltungsprogramm, voll digitalisiert.',
  },
];
---

<BaseLayout title="Phönix Maklerverbund – Ihr Mehrwert-Verbund">
  <section class="hero">
    <div class="container hero-inner">
      <span class="eyebrow">Phönix Maklerverbund</span>
      <h1>Ihr Mehrwert-Verbund<br />für Finanz- und Versicherungslösungen</h1>
      <p class="lead">
        Seit 2012 unterstützt der Phönix Maklerverbund ungebundene Versicherungsmakler
        und ihre Kunden mit Fachwissen, exklusiven Vereinbarungen und persönlicher Beratung.
      </p>
      <div class="hero-cta">
        <a href="/makler-werden" class="btn btn-primary">Ich möchte Partner werden <span aria-hidden="true">→</span></a>
        <a href="/kunde" class="btn btn-outline">Ich bin Kunde <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header text-center">
        <span class="eyebrow">Warum Phönix?</span>
        <h2>Vier Gründe, die für uns sprechen</h2>
      </div>
      <div class="grid grid-4 vorteile-grid">
        {vorteile.map((v) => (
          <article class="vorteil-card">
            <div class="vorteil-icon" aria-hidden="true">{v.icon}</div>
            <h3>{v.title}</h3>
            <p>{v.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container partner-net">
      <div class="partner-net-text">
        <span class="eyebrow">Unser Netzwerk</span>
        <h2>Stark durch Partnerschaft</h2>
        <p>
          Durch unsere Netzwerkorganisation bieten wir Ihnen Zugang zu exklusiven Ressourcen,
          Weiterbildungsprogrammen und einer starken Verhandlungsposition gegenüber Anbietern.
          Unsere Partnerschaften mit den führenden Versicherern garantieren Ihnen erstklassige
          Bedingungen und Produkte.
        </p>
        <a href="/ueber-uns" class="btn btn-ghost">Mehr über uns →</a>
      </div>
      <div class="partner-net-image">
        <img src="/images/partner-netzwerk.webp" alt="Partner-Netzwerk Grafik" width="600" height="400" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="section cta-band">
    <div class="container text-center">
      <h2>Bereit, Teil des Phönix Netzwerks zu werden?</h2>
      <p class="lead" style="margin-inline:auto;">
        Als Teil des Phönix Maklerverbunds profitieren Sie von unserer langjährigen Erfahrung,
        exklusiven Courtagen und einer starken Gemeinschaft.
      </p>
      <a href="/makler-werden" class="btn btn-primary btn-lg">Jetzt Partner werden →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: clamp(3rem, 8vw, 6rem);
    background: linear-gradient(135deg, var(--color-primary-light) 0%, #ffffff 100%);
  }

  .hero-inner {
    max-width: 820px;
  }

  .hero h1 {
    margin-bottom: 1.5rem;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }

  .section-header {
    max-width: 720px;
    margin: 0 auto 3rem;
  }

  .vorteile-grid {
    gap: 1.5rem;
  }

  .vorteil-card {
    padding: 2rem 1.5rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
  }

  .vorteil-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary-light);
  }

  .vorteil-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .vorteil-card h3 {
    margin-bottom: 0.5rem;
    font-size: 1.125rem;
  }

  .vorteil-card p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .partner-net {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (max-width: 768px) {
    .partner-net {
      grid-template-columns: 1fr;
    }
  }

  .partner-net-image img {
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .cta-band h2 {
    margin-bottom: 1rem;
  }

  .cta-band .btn {
    margin-top: 2rem;
  }

  .btn-lg {
    padding: 1rem 2rem;
    font-size: 1.05rem;
  }
</style>
