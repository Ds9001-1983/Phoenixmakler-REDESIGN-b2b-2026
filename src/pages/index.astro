---
import BaseLayout from '../layouts/BaseLayout.astro';

const prinzipien = [
  {
    num: '01',
    title: 'Ungebunden',
    text: 'Wir sind 100% inhabergeführt. Keine Beteiligungen von Versicherern oder Kapitalgebern — nur Ihre Interessen zählen.',
  },
  {
    num: '02',
    title: 'Exklusiv',
    text: 'Besondere Courtagen, exklusive Vereinbarungen und rechtssichere Rahmenverträge, die Ihnen als Makler den Rücken freihalten.',
  },
  {
    num: '03',
    title: 'Digital',
    text: 'Professional Works MVP kostenlos, volle Digitalisierung, moderne Tools — damit Sie sich auf Ihre Kunden konzentrieren können.',
  },
  {
    num: '04',
    title: 'Gemeinschaft',
    text: 'Regelmäßige Online-Meetings, Marktaktualisierungen, Deckungskonzepte. Über 120 Maklerinnen und Makler teilen Wissen und Erfahrung.',
  },
];
---

<BaseLayout title="Phönix Maklerverbund – Ihr Mehrwert-Verbund">
  {/* HERO */}
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-text" data-reveal>
        <span class="eyebrow">Phönix Maklerverbund · seit 2012</span>
        <h1 class="hero-headline" data-split>
          Der Verbund <em>für Makler,</em> die frei bleiben wollen.
        </h1>
        <p class="lead" data-reveal data-reveal-delay="2">
          Über 120 ungebundene Versicherungsmaklerinnen und -makler. Ein inhabergeführter
          Netzwerkpartner. Exklusive Courtagen, digitale Tools und ein Team, das Sie kennt.
        </p>
        <div class="hero-cta" data-reveal data-reveal-delay="3">
          <a href="/makler-werden" class="btn btn-primary btn-lg">Partner werden</a>
          <a href="/kunde" class="btn btn-ghost">Für Kunden →</a>
        </div>
      </div>
      <figure class="hero-media" data-parallax-wrapper>
        <img
          src="/images/hero/hero-home.png"
          alt="Modernes Büro-Interieur im Phönix-Stil"
          width="1024"
          height="1024"
          loading="eager"
          fetchpriority="high"
          data-parallax="0.12"
        />
        <figcaption class="hero-meta">
          <span>Oberhonnefeld-Gierend</span>
          <span>Westerwald · DE</span>
        </figcaption>
      </figure>
    </div>
  </section>

  {/* KENNZAHLEN */}
  <section class="section-sm stats-band">
    <div class="container stats-grid">
      <div class="stat" data-reveal>
        <span class="stat-num" data-count="120" data-count-suffix="+">0</span>
        <span class="stat-label">Partner im Netzwerk</span>
      </div>
      <div class="stat" data-reveal data-reveal-delay="1">
        <span class="stat-num" data-count="12" data-count-suffix="">0</span>
        <span class="stat-label">Jahre Erfahrung</span>
      </div>
      <div class="stat" data-reveal data-reveal-delay="2">
        <span class="stat-num" data-count="100" data-count-suffix="%">0</span>
        <span class="stat-label">Inhabergeführt</span>
      </div>
      <div class="stat" data-reveal data-reveal-delay="3">
        <span class="stat-num">€0</span>
        <span class="stat-label">MVP-Kosten für Partner</span>
      </div>
    </div>
  </section>

  {/* PRINZIPIEN / EDITORIAL */}
  <section class="section section-prinzipien">
    <div class="container">
      <div class="prinzipien-head" data-reveal>
        <span class="eyebrow">Was uns anders macht</span>
        <h2 data-split>
          Vier Prinzipien, <em>eine</em> Haltung.
        </h2>
      </div>
      <ul class="prinzipien-list">
        {prinzipien.map((p, i) => (
          <li class="prinzip" data-reveal data-reveal-delay={i + 1}>
            <span class="prinzip-num">{p.num}</span>
            <div class="prinzip-body">
              <h3>{p.title}</h3>
              <p>{p.text}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* MANIFESTO — große editorial Quote */}
  <section class="section manifesto bg-dark">
    <div class="container container-narrow">
      <span class="eyebrow" style="color:var(--color-accent)">Unser Versprechen</span>
      <blockquote data-reveal data-split>
        Wir sind keine Zentrale, die Ihnen <em>Produkte verordnet</em> — wir sind ein Verbund,
        der Ihnen Entscheidungsfreiheit zurückgibt.
      </blockquote>
      <footer class="manifesto-footer" data-reveal data-reveal-delay="2">
        <div>
          <strong>Torsten Deterding &amp; Lothar Nast</strong>
          <span>Geschäftsführer · Phönix Maklerverbund GmbH</span>
        </div>
        <a href="/ueber-uns" class="btn btn-accent">Mehr über uns</a>
      </footer>
    </div>
  </section>

  {/* PFADE — B2B / B2C */}
  <section class="section pfade">
    <div class="container pfade-grid">
      <a href="/makler-werden" class="pfad" data-reveal>
        <span class="eyebrow">Für Maklerinnen &amp; Makler</span>
        <h3>Werden Sie Partner im&nbsp;Phönix&nbsp;Netzwerk.</h3>
        <p>Wechsel aus der Ausschließlichkeit, Support beim Aufbau, exklusive Vereinbarungen.</p>
        <span class="pfad-arrow">→</span>
      </a>
      <a href="/kunde" class="pfad pfad-alt" data-reveal data-reveal-delay="1">
        <span class="eyebrow">Für Kundinnen &amp; Kunden</span>
        <h3>Finden Sie Ihren <em>persönlichen</em> Makler.</h3>
        <p>Unsere Partner sind unabhängig, fair vergütet — und ausschließlich Ihren Anliegen verpflichtet.</p>
        <span class="pfad-arrow">→</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding-block: clamp(3rem, 6vw, 5rem) clamp(4rem, 7vw, 7rem);
    background: var(--color-cream);
    overflow: hidden;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  .hero-headline {
    margin-bottom: 1.75rem;
  }

  .hero-cta {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
  }

  .hero-media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4/5;
    background: var(--color-cream-warm);
  }

  @media (max-width: 900px) {
    .hero-media { aspect-ratio: 4/3; }
  }

  .hero-media img {
    width: 100%;
    height: 115%;
    object-fit: cover;
    transform: translateY(-7%);
  }

  .hero-meta {
    position: absolute;
    bottom: 1.25rem;
    left: 1.25rem;
    right: 1.25rem;
    display: flex;
    justify-content: space-between;
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-cream);
    mix-blend-mode: difference;
    font-weight: 500;
  }

  /* Stats band */
  .stats-band {
    background: var(--color-cream-warm);
    border-block: 1px solid var(--color-border);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  @media (max-width: 700px) {
    .stats-grid { grid-template-columns: 1fr 1fr; gap: 2.5rem 1.5rem; }
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-block: 0.5rem;
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    color: var(--color-primary);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  /* Prinzipien */
  .section-prinzipien { background: var(--color-cream); }

  .prinzipien-head {
    max-width: 620px;
    margin-bottom: clamp(2.5rem, 5vw, 4.5rem);
  }

  .prinzipien-head h2 em { font-style: italic; color: var(--color-accent-dark); font-weight: 400; }

  .prinzipien-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr;
  }

  .prinzip {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    padding: 2.5rem 0;
    border-top: 1px solid var(--color-border);
    align-items: baseline;
  }

  .prinzip:last-child { border-bottom: 1px solid var(--color-border); }

  @media (max-width: 560px) {
    .prinzip { grid-template-columns: 1fr; gap: 0.75rem; padding: 2rem 0; }
  }

  .prinzip-num {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--color-accent-dark);
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  .prinzip-body h3 {
    font-size: clamp(1.35rem, 2.4vw, 1.75rem);
    margin-bottom: 0.75rem;
  }

  .prinzip-body p {
    color: var(--color-text-muted);
    max-width: 58ch;
    font-size: 1.02rem;
  }

  /* Manifesto */
  .manifesto {
    padding-block: clamp(4rem, 8vw, 7rem);
  }

  .manifesto .eyebrow { color: var(--color-accent); }

  .manifesto blockquote {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.025em;
    color: var(--color-cream);
    margin-block: 2rem 3rem;
  }

  .manifesto blockquote em {
    font-style: italic;
    color: var(--color-accent);
  }

  .manifesto-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(201, 166, 107, 0.2);
    flex-wrap: wrap;
  }

  .manifesto-footer strong {
    display: block;
    color: var(--color-cream);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1.05rem;
    margin-bottom: 0.25rem;
  }

  .manifesto-footer span {
    display: block;
    color: rgba(250, 247, 242, 0.6);
    font-size: 0.88rem;
    letter-spacing: 0.02em;
  }

  /* Pfade (Split-Cards) */
  .pfade { padding-block: 0; }

  .pfade-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--color-border);
    background: var(--color-cream);
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .pfade-grid { grid-template-columns: 1fr; }
  }

  .pfad {
    position: relative;
    padding: clamp(2.5rem, 5vw, 5rem);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    color: var(--color-dark);
    transition: background-color 450ms var(--ease-out);
    border-right: 1px solid var(--color-border);
  }

  .pfad:last-child { border-right: 0; border-top: 0; }

  @media (max-width: 768px) {
    .pfad:last-child { border-top: 1px solid var(--color-border); }
  }

  .pfad h3 {
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    max-width: 18ch;
    line-height: 1.1;
  }

  .pfad h3 em { font-style: italic; color: var(--color-accent-dark); font-weight: 400; }

  .pfad p {
    color: var(--color-text-muted);
    max-width: 36ch;
  }

  .pfad-arrow {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-primary);
    margin-top: 0.5rem;
    transition: transform 380ms var(--ease-out);
  }

  .pfad:hover { background: var(--color-cream-warm); }
  .pfad:hover .pfad-arrow { transform: translateX(12px); }

  .pfad-alt:hover { background: var(--color-primary-light); }
</style>
