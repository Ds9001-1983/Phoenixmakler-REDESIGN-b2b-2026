---
import BaseLayout from '../layouts/BaseLayout.astro';
import vorteile from '../data/makler-werden-vorteile.json';
---

<BaseLayout title="Partner werden – Phönix Maklerverbund">
  {/* HERO split */}
  <section class="hero-b2b">
    <div class="container hero-grid">
      <div class="hero-text" data-reveal>
        <span class="eyebrow">Für Versicherungsmakler</span>
        <h1 data-split>
          Ein Verbund, der <em>für Sie</em> arbeitet — nicht umgekehrt.
        </h1>
        <p class="lead" data-reveal data-reveal-delay="2">
          Seit 2012 begleiten wir Vermittlerinnen und Vermittler in die Ungebundenheit.
          Mit exklusiven Courtagen, rechtssicheren Rahmenverträgen und einem Team,
          das Sie persönlich kennt.
        </p>
        <div class="hero-cta" data-reveal data-reveal-delay="3">
          <a href="#partner-werden" class="btn btn-primary btn-lg">Jetzt Partner werden</a>
          <a href="#vorteile" class="btn btn-ghost">Vorteile ansehen →</a>
        </div>
      </div>
      <figure class="hero-media" data-parallax-wrapper data-reveal data-reveal-delay="2">
        <img
          src="/images/hero/hero-makler.png"
          alt="Phönix-Makler Portrait"
          width="1024"
          height="1024"
          loading="eager"
          fetchpriority="high"
          data-parallax="0.1"
        />
      </figure>
    </div>
  </section>

  {/* VORTEILE editorial list */}
  <section class="section bg-cream" id="vorteile">
    <div class="container">
      <div class="sec-head" data-reveal>
        <span class="eyebrow">Dienstleistungen &amp; Vorteile</span>
        <h2 data-split>
          Drei Versprechen, <em>keine</em> Kompromisse.
        </h2>
      </div>
      <ul class="editorial-list">
        {vorteile.leistungen.map((item, i) => (
          <li class="editorial-item" data-reveal data-reveal-delay={i + 1}>
            <span class="editorial-num">0{i + 1}</span>
            <div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* SELBSTÄNDIGKEIT */}
  <section class="section split-feature bg-dark">
    <div class="container split-grid">
      <div data-reveal>
        <span class="eyebrow" style="color:var(--color-accent)">Ihre Selbständigkeit</span>
        <h2 data-split>
          Ihre Selbständigkeit, <em>unsere</em> Priorität.
        </h2>
        <p class="lead" style="color:rgba(250,247,242,0.78)">
          Wir fördern Ihre Selbständigkeit durch rechtlich eigenständige Vereinbarungen,
          damit Sie flexibel und sicher agieren können.
        </p>
      </div>
      <div class="check-col" data-reveal data-reveal-delay="2">
        <h3 style="color:var(--color-cream)">Alleinstellungsmerkmale</h3>
        <ul class="check-list">
          {vorteile.alleinstellung.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  {/* PRAKTISCHE UNTERSTÜTZUNG */}
  <section class="section bg-cream">
    <div class="container">
      <div class="sec-head" data-reveal>
        <span class="eyebrow">Praktische Unterstützung</span>
        <h2 data-split>
          Tools, die <em>wirklich</em> helfen.
        </h2>
      </div>
      <div class="grid grid-2 editorial-grid">
        {vorteile.unterstuetzung.map((item, i) => (
          <article class="editorial-card" data-reveal data-reveal-delay={i + 1}>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* NETWORKING */}
  <section class="section networking">
    <div class="container">
      <div class="networking-head" data-reveal>
        <span class="eyebrow">Networking &amp; Weiterbildung</span>
        <h2 data-split>
          Gemeinsam <em>stark</em> im Markt.
        </h2>
      </div>
      <ul class="check-list check-list-large">
        {vorteile.networking.map((item, i) => (
          <li data-reveal data-reveal-delay={i + 1}>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  {/* WECHSEL AUS DER AUSSCHLIESSLICHKEIT */}
  <section class="section bg-cream-warm wechsel">
    <div class="container">
      <div class="sec-head" data-reveal>
        <span class="eyebrow">Wechsel aus der Ausschließlichkeit</span>
        <h2 data-split>
          Schritt für Schritt in die <em>Ungebundenheit</em>.
        </h2>
        <p class="lead">
          Wenn Sie einen Wechsel in Erwägung ziehen, berücksichtigen Sie vertragliche
          Details und Kündigungsfristen. Wir unterstützen Sie bei jedem Schritt.
        </p>
      </div>
      <div class="wechsel-grid">
        <div class="wechsel-col" data-reveal>
          <h3>Was zu beachten ist</h3>
          <ul class="check-list">
            {vorteile.wechsel_beachten.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
        <div class="wechsel-col" data-reveal data-reveal-delay="1">
          <h3>Wie wir Ihnen helfen</h3>
          <ul class="check-list">
            {vorteile.wechsel_hilfe.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  {/* MANIFESTO */}
  <section class="section bg-dark manifesto-b2b">
    <div class="container container-narrow">
      <blockquote data-reveal data-split>
        Der Phönix Maklerverbund steht für Transparenz, Qualität und die Förderung
        <em> Ihrer Selbständigkeit.</em>
      </blockquote>
    </div>
  </section>

  {/* FORMULAR */}
  <section class="section section-form" id="partner-werden">
    <div class="container">
      <div class="form-head" data-reveal>
        <span class="eyebrow">Jetzt loslegen</span>
        <h2>
          Ihre Partnerschaft <em>beginnt hier</em>.
        </h2>
        <p class="lead">
          Tragen Sie Ihre Daten ein — wir melden uns persönlich bei Ihnen.
        </p>
      </div>

      <form class="registrierung-form" data-registrierung novalidate data-reveal data-reveal-delay="1">
        <div class="form-row">
          <div class="form-field">
            <label for="anrede">Anrede *</label>
            <select id="anrede" name="anrede" required>
              <option value="">Bitte wählen</option>
              <option value="frau">Frau</option>
              <option value="herr">Herr</option>
              <option value="divers">Divers</option>
            </select>
          </div>
        </div>

        <div class="form-row grid-2">
          <div class="form-field">
            <label for="vorname">Vorname *</label>
            <input type="text" id="vorname" name="vorname" autocomplete="given-name" required />
          </div>
          <div class="form-field">
            <label for="nachname">Nachname *</label>
            <input type="text" id="nachname" name="nachname" autocomplete="family-name" required />
          </div>
        </div>

        <div class="form-row">
          <div class="form-field">
            <label for="strasse">Straße &amp; Hausnummer *</label>
            <input type="text" id="strasse" name="strasse" autocomplete="street-address" required />
          </div>
        </div>

        <div class="form-row grid-2">
          <div class="form-field form-field-sm">
            <label for="plz">PLZ *</label>
            <input type="text" id="plz" name="plz" autocomplete="postal-code" inputmode="numeric" pattern="[0-9]{5}" required />
          </div>
          <div class="form-field">
            <label for="ort">Ort *</label>
            <input type="text" id="ort" name="ort" autocomplete="address-level2" required />
          </div>
        </div>

        <div class="form-row grid-2">
          <div class="form-field">
            <label for="telefon">Telefon *</label>
            <input type="tel" id="telefon" name="telefon" autocomplete="tel" required />
          </div>
          <div class="form-field">
            <label for="email">E-Mail *</label>
            <input type="email" id="email" name="email" autocomplete="email" required />
          </div>
        </div>

        <div class="form-row grid-2">
          <div class="form-field">
            <label for="geburtsdatum">Geburtsdatum *</label>
            <input type="date" id="geburtsdatum" name="geburtsdatum" required />
          </div>
          <div class="form-field">
            <label for="nationalitaet">Nationalität *</label>
            <select id="nationalitaet" name="nationalitaet" required>
              <option value="">Bitte wählen</option>
              <option value="DE">Deutschland</option>
              <option value="AT">Österreich</option>
              <option value="CH">Schweiz</option>
              <option value="other">Andere</option>
            </select>
          </div>
        </div>

        <div class="form-row">
          <div class="form-field">
            <label for="ihk">IHK-Vermittlerregisternummer <span class="optional">(optional)</span></label>
            <input type="text" id="ihk" name="ihk" />
          </div>
        </div>

        <div class="form-checks">
          <label class="check">
            <input type="checkbox" name="datenschutz" required />
            <span>Ich habe die <a href="/datenschutz">Datenschutzerklärung</a> gelesen und stimme zu. *</span>
          </label>
          <label class="check">
            <input type="checkbox" name="kontakt_ok" />
            <span>Ich möchte von Phönix kontaktiert werden.</span>
          </label>
        </div>

        <div class="form-submit">
          <button type="submit" class="btn btn-primary btn-lg">Jetzt Partner werden →</button>
          <p class="form-hint">
            Hinweis: Die automatische Übermittlung wird nach Freischaltung des CRM-Zugangs aktiviert.
          </p>
        </div>

        <div class="form-success" data-form-success hidden>
          <h3>Vielen Dank für Ihr Interesse!</h3>
          <p>Wir melden uns in Kürze persönlich bei Ihnen.</p>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  /* HERO */
  .hero-b2b {
    padding-block: clamp(3rem, 6vw, 5rem) clamp(4rem, 7vw, 7rem);
    background: var(--color-cream);
    overflow: hidden;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  .hero-text h1 { margin-bottom: 1.5rem; }
  .hero-text h1 em { font-style: italic; color: var(--color-accent-dark); font-weight: 400; }

  .hero-cta {
    display: flex;
    gap: 2rem;
    align-items: center;
    margin-top: 2.5rem;
    flex-wrap: wrap;
  }

  .hero-media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4/5;
    background: var(--color-cream-warm);
  }

  @media (max-width: 900px) {
    .hero-media { aspect-ratio: 4/3; }
  }

  .hero-media img {
    width: 100%;
    height: 115%;
    object-fit: cover;
    transform: translateY(-7%);
  }

  /* Section-Head */
  .sec-head {
    max-width: 640px;
    margin-bottom: clamp(2.5rem, 5vw, 4.5rem);
  }

  .sec-head h2 em { font-style: italic; color: var(--color-accent-dark); font-weight: 400; }

  /* Editorial List */
  .editorial-list { list-style: none; }

  .editorial-item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: clamp(1.5rem, 4vw, 4rem);
    padding: 2.5rem 0;
    border-top: 1px solid var(--color-border);
    align-items: baseline;
  }

  .editorial-item:last-child { border-bottom: 1px solid var(--color-border); }

  @media (max-width: 560px) {
    .editorial-item { grid-template-columns: 1fr; gap: 0.75rem; padding: 2rem 0; }
  }

  .editorial-num {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--color-accent-dark);
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  .editorial-item h3 {
    font-size: clamp(1.35rem, 2.4vw, 1.75rem);
    margin-bottom: 0.75rem;
  }

  .editorial-item p {
    color: var(--color-text-muted);
    max-width: 58ch;
    font-size: 1.02rem;
  }

  /* Split-Feature dark */
  .split-feature { padding-block: clamp(4rem, 8vw, 7rem); }

  .split-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(2rem, 6vw, 6rem);
    align-items: start;
  }

  @media (max-width: 900px) { .split-grid { grid-template-columns: 1fr; } }

  .split-feature h2 em { font-style: italic; color: var(--color-accent); font-weight: 400; }
  .split-feature h2 { color: var(--color-cream); }
  .split-feature .lead { margin-top: 1.5rem; }

  .check-col h3 { color: var(--color-cream); margin-bottom: 1.5rem; font-size: 1.1rem; }

  /* Check List */
  .check-list { list-style: none; display: flex; flex-direction: column; gap: 1rem; }

  .check-list li {
    padding-left: 2.25rem;
    position: relative;
    padding-block: 0.25rem;
    line-height: 1.5;
  }

  .check-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 18px;
    height: 1px;
    background: var(--color-accent);
  }

  .bg-dark .check-list li { color: rgba(250, 247, 242, 0.85); }

  .check-list-large li {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 2vw, 1.5rem);
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-dark);
    padding-block: 0.75rem;
  }

  .check-list-large li::before { top: 1em; width: 24px; }

  /* Editorial Cards */
  .editorial-grid { gap: 0; }

  .editorial-card {
    padding: clamp(2rem, 4vw, 3rem);
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-right-width: 0;
    transition: background-color 300ms ease;
  }

  .editorial-card:last-child { border-right-width: 1px; }

  @media (max-width: 540px) {
    .editorial-card { border-right-width: 1px; border-bottom-width: 0; }
    .editorial-card:last-child { border-bottom-width: 1px; }
  }

  .editorial-card:hover { background: var(--color-cream-warm); }

  .editorial-card h3 {
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    margin-bottom: 0.9rem;
    color: var(--color-primary);
  }

  .editorial-card p {
    color: var(--color-text-muted);
  }

  /* Networking */
  .networking { background: var(--color-cream); }
  .networking-head { max-width: 640px; margin-bottom: 3rem; }
  .networking-head h2 em { font-style: italic; color: var(--color-accent-dark); font-weight: 400; }

  /* Wechsel */
  .wechsel-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  @media (max-width: 768px) { .wechsel-grid { grid-template-columns: 1fr; } }

  .wechsel-col h3 {
    font-size: 1.1rem;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
  }

  .wechsel h2 em { font-style: italic; color: var(--color-accent-dark); font-weight: 400; }

  /* Manifesto B2B */
  .manifesto-b2b { padding-block: clamp(4rem, 8vw, 7rem); }

  .manifesto-b2b blockquote {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-cream);
    letter-spacing: -0.025em;
    text-align: center;
  }

  .manifesto-b2b blockquote em { font-style: italic; color: var(--color-accent); }

  /* FORMULAR */
  .section-form { background: var(--color-cream-warm); }

  .form-head {
    max-width: 620px;
    margin: 0 auto clamp(2rem, 4vw, 3rem);
    text-align: center;
  }

  .form-head h2 em { font-style: italic; color: var(--color-accent-dark); font-weight: 400; }
  .form-head .lead { margin-inline: auto; margin-top: 1rem; }

  .registrierung-form {
    max-width: 720px;
    margin: 0 auto;
    background: var(--color-cream);
    padding: clamp(1.75rem, 4vw, 3rem);
    border: 1px solid var(--color-border);
  }

  .form-row { margin-bottom: 1.5rem; }
  .form-row.grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 540px) {
    .form-row.grid-2 { grid-template-columns: 1fr; }
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-field label {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .optional { color: var(--color-text-muted); font-weight: 400; text-transform: none; letter-spacing: 0; }

  .form-field input,
  .form-field select {
    min-height: var(--min-touch-target);
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0;
    background: var(--color-cream);
    font-size: 1rem;
    transition: border-color 220ms ease, background-color 220ms ease;
  }

  .form-field input:focus,
  .form-field select:focus {
    outline: none;
    border-color: var(--color-primary);
    background: #fff;
  }

  .form-checks {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    margin-block: 2rem;
    padding-block: 1.5rem;
    border-block: 1px solid var(--color-border);
  }

  .check {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    font-size: 0.95rem;
    cursor: pointer;
  }

  .check input {
    margin-top: 0.2rem;
    width: 1.1rem;
    height: 1.1rem;
    accent-color: var(--color-primary);
  }

  .check a { color: var(--color-primary); text-decoration: underline; }

  .form-submit { text-align: center; }
  .form-submit .btn { min-width: 260px; }

  .form-hint {
    margin-top: 1.25rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    max-width: 42ch;
    margin-inline: auto;
  }

  .form-success { text-align: center; padding: 2rem; }
  .form-success h3 { color: var(--color-primary); margin-bottom: 0.5rem; }
</style>

<script>
  // TODO(Phase 2): PW-API "Nutzer erstellen" anbinden, sobald CRM-Zugang vorliegt.
  const form = document.querySelector<HTMLFormElement>('[data-registrierung]');
  const success = document.querySelector<HTMLElement>('[data-form-success]');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    form.style.display = 'none';
    if (success) {
      success.hidden = false;
      success.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  });
</script>
