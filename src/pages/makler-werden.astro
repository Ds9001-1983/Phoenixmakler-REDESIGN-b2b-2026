---
// Partner werden — Premium-10K B2B-Deep-Dive.
// Wiederverwendet Startseiten-Sektionen (StatsBand, ValueProps, ProcessPin,
// FoundersQuote, FooterCinematic) + eigene Makler-Sektionen (Hero, Wechsel, Form).
import BaseLayout from '../layouts/BaseLayout.astro';
import MaklerHero from '../components/sections/MaklerHero.astro';
import StatsBand from '../components/sections/StatsBand.astro';
import ValueProps from '../components/sections/ValueProps.astro';
import ProcessPin from '../components/sections/ProcessPin.astro';
import WechselJourney from '../components/sections/WechselJourney.astro';
import FoundersQuote from '../components/sections/FoundersQuote.astro';
import MaklerForm from '../components/sections/MaklerForm.astro';
import FooterCinematic from '../components/sections/FooterCinematic.astro';
---

<BaseLayout
  title="Partner werden – Phönix Maklerverbund"
  description="Ungebundener Versicherungsmakler-Verbund für erfahrene Maklerinnen und Makler. Exklusive Courtagen, rechtssichere Rahmenverträge, Maklerverwaltungsprogramm kostenfrei."
  hideFooter={true}
>
  <MaklerHero />
  <StatsBand />
  <ValueProps />
  <ProcessPin />
  <WechselJourney />
  <FoundersQuote />
  <MaklerForm />
  <FooterCinematic />
</BaseLayout>
