---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatsBand from '../components/sections/StatsBand.astro';
import FoundersQuote from '../components/sections/FoundersQuote.astro';
import SplitCTA from '../components/sections/SplitCTA.astro';
import FooterCinematic from '../components/sections/FooterCinematic.astro';
---

<BaseLayout
  title="Über uns – Phönix Maklerverbund"
  description="Phönix Maklerverbund — inhabergeführt seit 2012. Torsten Deterding und Lothar Nast führen den ungebundenen Verbund mit über 120 Partnern."
  hideFooter={true}
>
  {/* HERO EDITORIAL */}
  <section class="uu-hero">
    <div class="uu-hero__container">
      <div class="uu-hero__text">
        <span class="uu-hero__caption">Über uns</span>
        <h1 class="uu-hero__title" data-split="words" data-split-trigger="load" data-split-stagger="0.07" data-split-delay="0.2">
          Ein Verbund,<br/>
          <em>zwei Köpfe,</em><br/>
          eine Haltung.
        </h1>
        <p class="uu-hero__lead" data-reveal data-reveal-delay="3">
          Der Phönix Maklerverbund ist unser Lebensprojekt. Seit 2012 bauen wir einen Ort,
          an dem unabhängige Versicherungsmaklerinnen und -makler arbeiten können, wie sie
          arbeiten wollen — ungebunden, rechtssicher, gut vernetzt.
        </p>
      </div>
    </div>
  </section>

  <StatsBand />

  {/* GESCHICHTE */}
  <section class="uu-story">
    <div class="uu-story__container">
      <div class="uu-story__intro">
        <span class="uu-story__caption">Unsere Geschichte</span>
        <h2 class="uu-story__headline">
          Gestartet als Idee.<br/>
          Gewachsen zu einem <em>Netzwerk.</em>
        </h2>
      </div>

      <div class="uu-story__body">
        <p data-reveal>
          Am <strong>20. Juni 2012</strong> haben wir mit einer Handvoll Kollegen angefangen.
          Die Idee: einen Verbund schaffen, der Makler stark macht, ohne sie zu vereinnahmen.
          Kein Vertrieb, keine Zentrale, die Produkte verordnet — sondern ein Netzwerk, das
          den Rücken freihält.
        </p>
        <p data-reveal data-reveal-delay="1">
          Heute sind wir über <strong>120 Maklerinnen und Makler</strong>, die gemeinsam
          starke Sondervereinbarungen aushandeln, Deckungskonzepte entwickeln und sich bei
          Bestandsumdeckungen gegenseitig helfen.
        </p>
        <p data-reveal data-reveal-delay="2">
          <strong>Ungebundenheit ist Kernwert.</strong> Anders als viele Maklerverbünde sind
          wir 100 % inhabergeführt. Keine Beteiligungen von Kapitalgebern, keine
          strategischen Partnerschaften mit Versicherern, die Produktempfehlungen färben.
        </p>
      </div>
    </div>
  </section>

  {/* GESCHÄFTSFÜHRUNG */}
  <section class="uu-gf">
    <div class="uu-gf__container">
      <div class="uu-gf__intro" data-reveal>
        <span class="uu-gf__caption">Die Köpfe</span>
        <h2 class="uu-gf__headline">
          Zwei Partner.<br/>
          <em>Dieselbe</em> Überzeugung.
        </h2>
      </div>

      <div class="uu-gf__grid">
        <article class="uu-gf__card" data-reveal>
          <div class="uu-gf__media">
            <img src="/images/torsten-deterding.jpg" alt="Torsten Deterding" loading="lazy" />
          </div>
          <div class="uu-gf__body">
            <span class="uu-gf__role">Seit 1997 in der Assekuranz</span>
            <h3 class="uu-gf__name">Torsten Deterding</h3>
            <p class="uu-gf__bio">
              Versicherungsfachwirt. Verantwortlich für Vertrieb, Abrechnung und die
              technische Plattform des Phönix Maklerverbunds. Verbindet Praxiswissen aus
              der Assekuranz mit einem klaren Blick für effiziente Prozesse und digitale
              Lösungen.
            </p>
          </div>
        </article>

        <article class="uu-gf__card" data-reveal data-reveal-delay="1">
          <div class="uu-gf__media">
            <img src="/images/lothar-nast.jpg" alt="Lothar Nast" loading="lazy" />
          </div>
          <div class="uu-gf__body">
            <span class="uu-gf__role">Seit 1988 in der Assekuranz</span>
            <h3 class="uu-gf__name">Lothar Nast</h3>
            <p class="uu-gf__bio">
              Versicherungsfachwirt und Versicherungskaufmann mit jahrzehntelanger
              Erfahrung. Im Phönix Maklerverbund kümmert er sich um alle operativen und
              betrieblichen Themen sowie um juristische Fragestellungen. Sein Anspruch:
              klare, belastbare Regelungen schaffen, damit Makler sich auf ihre Kunden und
              ihr Geschäft konzentrieren können.
            </p>
          </div>
        </article>
      </div>

      <blockquote class="uu-gf__quote" data-reveal data-reveal-delay="2">
        „Unser Beruf ist uns auch <em>Berufung.</em>"
      </blockquote>
    </div>
  </section>

  <FoundersQuote />

  {/* WERTE */}
  <section class="uu-werte">
    <div class="uu-werte__container">
      <div class="uu-werte__intro">
        <span class="uu-werte__caption">Was uns trägt</span>
        <h2 class="uu-werte__headline">
          Drei Prinzipien,<br/>
          seit dem <em>ersten Tag.</em>
        </h2>
      </div>

      <div class="uu-werte__grid">
        <article class="uu-werte__item" data-reveal>
          <span class="uu-werte__num">01</span>
          <h3>Transparenz</h3>
          <p>Klare Konditionen, offene Courtagen, keine versteckten Margen. Du weißt jederzeit, worauf du dich einlässt.</p>
        </article>
        <article class="uu-werte__item" data-reveal data-reveal-delay="1">
          <span class="uu-werte__num">02</span>
          <h3>Qualität</h3>
          <p>Nicht jede Anfrage führt zur Aufnahme. Wir prüfen Haltung, Expertise und passen zueinander — oder eben nicht.</p>
        </article>
        <article class="uu-werte__item" data-reveal data-reveal-delay="2">
          <span class="uu-werte__num">03</span>
          <h3>Selbständigkeit</h3>
          <p>Rechtlich eigenständige Vereinbarungen, keine Einbindung in eine Konzernstruktur. Du bleibst, wer du bist.</p>
        </article>
      </div>
    </div>
  </section>

  <SplitCTA />
  <FooterCinematic />
</BaseLayout>

<style>
  .uu-hero {
    padding-block: clamp(6rem, 12vh, 10rem) clamp(3rem, 6vh, 5rem);
    background: var(--color-bg);
  }
  .uu-hero__container {
    max-width: var(--content-max-width);
    margin-inline: auto;
    padding-inline: var(--padding-x);
  }
  .uu-hero__caption {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
    margin-bottom: 1.5rem;
  }
  .uu-hero__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 7rem);
    font-weight: 400;
    line-height: 0.96;
    letter-spacing: -0.035em;
    color: var(--color-ink);
    margin: 0;
    max-width: 16ch;
    font-variation-settings: 'opsz' 144, 'SOFT' 100;
  }
  .uu-hero__title em {
    font-style: italic;
    font-weight: 300;
    color: var(--color-accent);
  }
  .uu-hero__lead {
    margin-top: 2rem;
    font-size: clamp(1.05rem, 1.35vw, 1.2rem);
    line-height: 1.55;
    color: var(--color-text-muted);
    max-width: 58ch;
  }

  /* STORY */
  .uu-story {
    padding-block: clamp(5rem, 10vh, 8rem);
    background: var(--color-bg-warm);
  }
  .uu-story__container {
    max-width: var(--content-max-width);
    margin-inline: auto;
    padding-inline: var(--padding-x);
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }
  .uu-story__caption {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
    margin-bottom: 1rem;
  }
  .uu-story__headline {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin: 0;
    position: sticky;
    top: 100px;
    font-variation-settings: 'opsz' 144, 'SOFT' 75;
  }
  .uu-story__headline em {
    font-style: italic;
    font-weight: 300;
    color: var(--color-accent);
  }
  .uu-story__body {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .uu-story__body p {
    font-size: 1.08rem;
    line-height: 1.7;
    color: var(--color-text);
    max-width: 58ch;
  }

  @media (max-width: 820px) {
    .uu-story__container { grid-template-columns: 1fr; gap: 2rem; }
    .uu-story__headline { position: static; }
  }

  /* GF */
  .uu-gf {
    padding-block: clamp(5rem, 10vh, 8rem);
    background: var(--color-bg);
  }
  .uu-gf__container {
    max-width: var(--content-max-width);
    margin-inline: auto;
    padding-inline: var(--padding-x);
  }
  .uu-gf__intro {
    max-width: 28ch;
    margin-bottom: clamp(3rem, 6vh, 5rem);
  }
  .uu-gf__caption {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
    margin-bottom: 1rem;
  }
  .uu-gf__headline {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin: 0;
    font-variation-settings: 'opsz' 144, 'SOFT' 75;
  }
  .uu-gf__headline em {
    font-style: italic;
    font-weight: 300;
    color: var(--color-accent);
  }
  .uu-gf__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }
  .uu-gf__card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg-warm);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }
  .uu-gf__media {
    aspect-ratio: 4/5;
    overflow: hidden;
    background: var(--color-primary-dark);
  }
  .uu-gf__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.9);
  }
  .uu-gf__body {
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .uu-gf__role {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
  }
  .uu-gf__name {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    color: var(--color-ink);
    margin: 0;
    letter-spacing: -0.02em;
  }
  .uu-gf__bio {
    font-size: 0.98rem;
    line-height: 1.55;
    color: var(--color-text-muted);
    max-width: 44ch;
    margin: 0;
  }
  .uu-gf__quote {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: clamp(4rem, 8vw, 6rem) auto 0;
    max-width: 24ch;
    text-align: center;
    font-variation-settings: 'opsz' 144, 'SOFT' 100;
  }
  .uu-gf__quote em {
    font-style: italic;
    color: var(--color-accent);
  }

  @media (max-width: 720px) {
    .uu-gf__grid { grid-template-columns: 1fr; }
  }

  /* WERTE */
  .uu-werte {
    padding-block: clamp(5rem, 10vh, 8rem);
    background: var(--color-bg-warm);
  }
  .uu-werte__container {
    max-width: var(--content-max-width);
    margin-inline: auto;
    padding-inline: var(--padding-x);
  }
  .uu-werte__intro {
    max-width: 28ch;
    margin-bottom: clamp(3rem, 6vh, 5rem);
  }
  .uu-werte__caption {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
    margin-bottom: 1rem;
  }
  .uu-werte__headline {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin: 0;
    font-variation-settings: 'opsz' 144, 'SOFT' 75;
  }
  .uu-werte__headline em {
    font-style: italic;
    font-weight: 300;
    color: var(--color-accent);
  }
  .uu-werte__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }
  .uu-werte__item {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(10,25,64,0.12);
  }
  .uu-werte__num {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    color: var(--color-accent-dark);
  }
  .uu-werte__item h3 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.2vw, 1.85rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0;
  }
  .uu-werte__item p {
    font-size: 0.98rem;
    line-height: 1.55;
    color: var(--color-text-muted);
    margin: 0;
    max-width: 40ch;
  }

  @media (max-width: 820px) {
    .uu-werte__grid { grid-template-columns: 1fr; }
  }
</style>
