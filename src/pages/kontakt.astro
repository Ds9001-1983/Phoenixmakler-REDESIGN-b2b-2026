---
import BaseLayout from '../layouts/BaseLayout.astro';
import navigation from '../data/navigation.json';
const k = navigation.kontakt;
---

<BaseLayout title="Kontakt – Phönix Maklerverbund">
  <section class="hero-kontakt">
    <div class="container" data-reveal>
      <span class="eyebrow">Kontakt</span>
      <h1>Persönlich.<br /><span class="accent">Direkt.</span></h1>
      <p class="lead">
        Telefon, E-Mail, persönliches Gespräch — wir sind für Sie erreichbar.
      </p>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container kontakt-grid">
      <article class="kontakt-card" data-reveal>
        <div class="kontakt-icon" aria-hidden="true">☎</div>
        <span class="kontakt-label">Telefon</span>
        <a href={k.telefon_href} class="kontakt-large">{k.telefon}</a>
        <p>Mo–Fr · 9–17 Uhr<br />Fax: {k.fax}</p>
      </article>

      <article class="kontakt-card" data-reveal data-reveal-delay="1">
        <div class="kontakt-icon" aria-hidden="true">✉</div>
        <span class="kontakt-label">E-Mail</span>
        <a href={`mailto:${k.email}`} class="kontakt-large">{k.email}</a>
        <p>Wir antworten in der Regel innerhalb eines Werktages.</p>
      </article>

      <article class="kontakt-card" data-reveal data-reveal-delay="2">
        <div class="kontakt-icon" aria-hidden="true">⌖</div>
        <span class="kontakt-label">Adresse</span>
        <address>
          <strong>{k.firma}</strong><br />
          {k.strasse}<br />
          {k.plz_ort}
        </address>
        <a href={k.maps} target="_blank" rel="noopener" class="btn btn-ghost">In Google Maps öffnen</a>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-kontakt {
    padding-block: clamp(3rem, 6vw, 5rem);
    background: var(--color-bg);
  }

  .hero-kontakt h1 .accent { color: var(--color-primary); }
  .hero-kontakt .lead { margin-top: 1.5rem; }

  .kontakt-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .kontakt-card {
    padding: clamp(2rem, 3.5vw, 2.5rem);
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    transition: border-color 260ms ease, transform 260ms var(--ease-out), box-shadow 260ms ease;
  }

  .kontakt-card:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .kontakt-icon {
    font-size: 1.75rem;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    background: var(--color-bg-soft);
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .kontakt-label {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    font-weight: 600;
  }

  .kontakt-large {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    font-weight: 700;
    color: var(--color-ink);
    word-break: break-word;
    letter-spacing: -0.02em;
    transition: color 220ms ease;
  }

  .kontakt-large:hover { color: var(--color-primary); }

  .kontakt-card address {
    font-style: normal;
    line-height: 1.6;
    color: var(--color-text);
  }

  .kontakt-card p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
</style>
