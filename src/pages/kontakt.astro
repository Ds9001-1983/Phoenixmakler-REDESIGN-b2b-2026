---
import BaseLayout from '../layouts/BaseLayout.astro';
import navigation from '../data/navigation.json';
const k = navigation.kontakt;
---

<BaseLayout title="Kontakt – Phönix Maklerverbund">
  <section class="hero-kontakt">
    <div class="container">
      <span class="eyebrow">Kontakt</span>
      <h1>So erreichen Sie uns</h1>
      <p class="lead">
        Persönlich, schnell und direkt. Wir freuen uns auf Ihre Nachricht.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container kontakt-grid">
      <div class="kontakt-card" data-reveal>
        <h2>Telefon</h2>
        <a href={k.telefon_href} class="kontakt-large">{k.telefon}</a>
        <p>Fax: {k.fax}</p>
      </div>
      <div class="kontakt-card" data-reveal data-reveal-delay="1">
        <h2>E-Mail</h2>
        <a href={`mailto:${k.email}`} class="kontakt-large">{k.email}</a>
        <p>Wir antworten in der Regel innerhalb eines Werktages.</p>
      </div>
      <div class="kontakt-card" data-reveal data-reveal-delay="2">
        <h2>Adresse</h2>
        <address>
          {k.firma}<br />
          {k.strasse}<br />
          {k.plz_ort}
        </address>
        <p>
          <a href={k.maps} target="_blank" rel="noopener" class="btn btn-ghost">In Google Maps öffnen →</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-kontakt {
    padding-block: clamp(3rem, 7vw, 5.5rem);
    background: linear-gradient(135deg, var(--color-primary-light) 0%, #ffffff 100%);
  }

  .kontakt-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .kontakt-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .kontakt-card h2 {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary-dark);
    margin-bottom: 0.5rem;
  }

  .kontakt-large {
    font-size: clamp(1.15rem, 2vw, 1.35rem);
    font-weight: 600;
    color: var(--color-dark);
    word-break: break-word;
  }

  .kontakt-large:hover {
    color: var(--color-primary-dark);
  }

  .kontakt-card address {
    font-style: normal;
    line-height: 1.6;
  }

  .kontakt-card p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }
</style>
