---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 – Seite nicht gefunden"
  description="Die gesuchte Seite existiert nicht. Zurück zur Startseite oder direkt zu Kontakt, Partner-werden oder Kundenbereich."
  showPreloader={false}
>
  <section class="nf">
    <div class="nf__inner">
      <span class="nf__eyebrow">404 · Seite nicht gefunden</span>
      <h1 class="nf__title">
        Hier ist <em>nichts</em>.<br />
        Aber das ist nicht <em>endgültig</em>.
      </h1>
      <p class="nf__lead">
        Die Seite, die du suchst, existiert nicht (mehr) oder hat eine neue Adresse bekommen.
        Wähle einen der Wege darunter — oder ruf uns einfach an.
      </p>

      <div class="nf__links">
        <a href="/" class="btn btn-accent">Zur Startseite</a>
        <a href="/kunde" class="nf__link">Kundenbereich</a>
        <a href="/makler-werden" class="nf__link">Partner werden</a>
        <a href="/kontakt" class="nf__link">Kontakt</a>
      </div>

      <p class="nf__hint">
        Direktwahl: <a href="tel:+4926346598580">02634&nbsp;659858-0</a>
        · <a href="mailto:info@phoenix-maklerverbund.de">info@phoenix-maklerverbund.de</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .nf {
    min-height: calc(100vh - 80px);
    min-height: calc(100dvh - 80px);
    display: flex;
    align-items: center;
    background: var(--color-bg-soft);
    padding: clamp(4rem, 10vh, 8rem) var(--padding-x);
  }
  .nf__inner {
    max-width: 720px;
    margin-inline: auto;
    text-align: center;
  }
  .nf__eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
    margin-bottom: 1.5rem;
  }
  .nf__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    line-height: 1.0;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin: 0 0 1.5rem;
    font-variation-settings: 'opsz' 144, 'SOFT' 100;
  }
  .nf__title em {
    font-style: italic;
    font-weight: 300;
    color: var(--color-accent);
  }
  .nf__lead {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 52ch;
    margin: 0 auto 2.5rem;
  }
  .nf__links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem 2rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }
  .nf__link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-border-strong);
    padding-bottom: 2px;
    transition: color 200ms, border-color 200ms;
  }
  .nf__link:hover {
    color: var(--color-accent-dark);
    border-bottom-color: var(--color-accent-dark);
  }
  .nf__hint {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0;
  }
  .nf__hint a {
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-border-strong);
    transition: border-color 200ms;
  }
  .nf__hint a:hover { border-bottom-color: var(--color-accent); }
</style>
