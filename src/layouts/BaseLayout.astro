---
import '../styles/global.css';
import '../styles/a11y.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Preloader from '../components/Preloader.astro';
import CustomCursor from '../components/CustomCursor.astro';
import AccessibilityWidget from '../components/AccessibilityWidget.astro';
import navigation from '../data/navigation.json';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  hideFooter?: boolean;
  noindex?: boolean;
  showPreloader?: boolean;
}

const {
  title,
  description = 'Phönix Maklerverbund – Ihr ungebundener Partner für Finanz- und Versicherungslösungen. Inhabergeführt seit 2012.',
  ogImage = '/images/hero/hero-home-og.jpg',
  hideFooter = false,
  noindex = false,
  showPreloader = true,
} = Astro.props;

const siteTitle = title.includes('Phönix') ? title : `${title} | Phönix Maklerverbund`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const siteOrigin = Astro.site?.origin ?? 'https://www.phoenix-maklerverbund.de';

// JSON-LD: nur auf der Startseite ausgeben — sonst dupliziert sich das Schema
// und Google bewertet Konsistenz hoeher als Mehrfach-Wiederholung.
const isHome = Astro.url.pathname === '/';
const jsonLd = isHome ? {
  '@context': 'https://schema.org',
  '@type': 'InsuranceAgency',
  name: navigation.kontakt.firma,
  url: siteOrigin,
  logo: `${siteOrigin}/images/logo.png`,
  image: `${siteOrigin}/images/hero/hero-home-og.jpg`,
  telephone: navigation.kontakt.telefon,
  email: navigation.kontakt.email,
  description: 'Inhabergefuehrter Maklerverbund fuer ungebundene Versicherungsmaklerinnen und -makler. Seit 2012 in Oberhonnefeld-Gierend.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: navigation.kontakt.strasse,
    postalCode: '56587',
    addressLocality: 'Oberhonnefeld-Gierend',
    addressRegion: 'Rheinland-Pfalz',
    addressCountry: 'DE',
  },
  openingHoursSpecification: [{
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '09:00',
    closes: '17:00',
  }],
  foundingDate: '2012',
  areaServed: 'DE',
  sameAs: [],
} : null;

// Datenschutzfreundliches Tracking ohne Cookies (Plausible oder Umami).
// Nur aktiv, wenn PUBLIC_PLAUSIBLE_DOMAIN oder PUBLIC_UMAMI_URL in .env gesetzt ist.
// Wird damit automatisch beim Deploy auf Produktion aktiviert, lokal aus.
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
const umamiUrl = import.meta.env.PUBLIC_UMAMI_URL;
const umamiId = import.meta.env.PUBLIC_UMAMI_ID;
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/png" href="/images/logo.png" />
    <link rel="apple-touch-icon" href="/images/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#0a1940" />
    {plausibleDomain && (
      <script defer data-domain={plausibleDomain} src="https://plausible.io/js/script.js"></script>
    )}
    {umamiUrl && umamiId && (
      <script defer src={umamiUrl} data-website-id={umamiId}></script>
    )}
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
    {/* A11y First-Paint: setzt data-a11y-* Attribute SYNCHRON vor dem ersten Render,
        sodass CSS-Variablen (Hochkontrast, Schriftgroesse, Reduce-Motion) sofort
        greifen und kein Flash entsteht. Muss inline und blockierend laufen. */}
    <script is:inline>
      (function () {
        try {
          var KEY = 'phoenix_a11y_v1';
          var defaults = {
            textSize: '100', spacing: 'normal', contrast: 'normal',
            motion: 'full', cursor: 'custom', links: 'normal', reading: 'off'
          };
          var raw = localStorage.getItem(KEY);
          var s = defaults;
          if (raw) {
            try {
              var p = JSON.parse(raw);
              if (p && typeof p === 'object') {
                for (var k in defaults) if (p[k]) s[k] = p[k];
              }
            } catch (e) {}
          }
          var prefersReduce = window.matchMedia &&
            window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          var motion = (s.motion === 'reduced' || prefersReduce) ? 'reduced' : 'full';
          var html = document.documentElement;
          html.setAttribute('data-a11y-text', s.textSize);
          html.setAttribute('data-a11y-spacing', s.spacing);
          html.setAttribute('data-a11y-contrast', s.contrast);
          html.setAttribute('data-a11y-motion', motion);
          html.setAttribute('data-a11y-cursor', s.cursor);
          html.setAttribute('data-a11y-links', s.links);
          html.setAttribute('data-a11y-reading', s.reading);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Zum Inhalt springen</a>
    {showPreloader && <Preloader />}
    <CustomCursor />
    <div class="scroll-progress" data-scroll-progress aria-hidden="true"></div>
    <Header />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    {!hideFooter && <Footer />}
    <AccessibilityWidget />
    <script>
      import '../scripts/motion.ts';
    </script>
  </body>
</html>

<style is:global>
  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left center;
    z-index: 9997;
    pointer-events: none;
  }
</style>
