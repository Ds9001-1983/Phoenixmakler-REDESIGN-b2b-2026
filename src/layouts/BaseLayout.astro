---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Preloader from '../components/Preloader.astro';
import CustomCursor from '../components/CustomCursor.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  hideFooter?: boolean;
}

const {
  title,
  description = 'Phönix Maklerverbund – Ihr ungebundener Partner für Finanz- und Versicherungslösungen. Inhabergeführt seit 2012.',
  ogImage = '/images/hero/hero-home.png',
  hideFooter = false,
} = Astro.props;

const siteTitle = title.includes('Phönix') ? title : `${title} | Phönix Maklerverbund`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();

// Datenschutzfreundliches Tracking ohne Cookies (Plausible oder Umami).
// Nur aktiv, wenn PUBLIC_PLAUSIBLE_DOMAIN oder PUBLIC_UMAMI_URL in .env gesetzt ist.
// Wird damit automatisch beim Deploy auf Produktion aktiviert, lokal aus.
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
const umamiUrl = import.meta.env.PUBLIC_UMAMI_URL;
const umamiId = import.meta.env.PUBLIC_UMAMI_ID;
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#0a1940" />
    {plausibleDomain && (
      <script defer data-domain={plausibleDomain} src="https://plausible.io/js/script.js"></script>
    )}
    {umamiUrl && umamiId && (
      <script defer src={umamiUrl} data-website-id={umamiId}></script>
    )}
  </head>
  <body>
    <a href="#main" class="skip-link">Zum Inhalt springen</a>
    <Preloader />
    <CustomCursor />
    <div class="scroll-progress" data-scroll-progress aria-hidden="true"></div>
    <Header />
    <main id="main">
      <slot />
    </main>
    {!hideFooter && <Footer />}
    <script>
      import '../scripts/motion.ts';
    </script>
  </body>
</html>

<style is:global>
  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left center;
    z-index: 9997;
    pointer-events: none;
  }
</style>
