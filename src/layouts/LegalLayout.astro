---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  eyebrow: string;
}
const { title, eyebrow } = Astro.props;
---

<BaseLayout title={`${title} – Phönix Maklerverbund`} showPreloader={false}>
  <section class="hero-legal">
    <div class="container" data-reveal>
      <span class="eyebrow">{eyebrow}</span>
      <h1>{title}</h1>
    </div>
  </section>

  <section class="section-sm bg-white">
    <div class="container-narrow legal-content" data-reveal>
      <slot />
    </div>
  </section>
</BaseLayout>

<style>
  .hero-legal {
    padding-block: clamp(4rem, 7vw, 6rem) clamp(2rem, 4vw, 3rem);
    background: var(--color-bg-soft);
  }

  .legal-content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-size: clamp(1.35rem, 2vw, 1.65rem);
  }

  .legal-content :global(h2:first-child) { margin-top: 0; }

  .legal-content :global(h3) {
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
    font-size: 1.05rem;
    color: var(--color-primary);
  }

  .legal-content :global(p) {
    margin-bottom: 1rem;
    max-width: none;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text);
  }

  .legal-content :global(ul) { margin-bottom: 1rem; padding-left: 1.25rem; }
  .legal-content :global(li) { margin-bottom: 0.45rem; line-height: 1.6; }
  .legal-content :global(strong) { color: var(--color-ink); font-weight: 600; }

  .legal-content :global(a) {
    color: var(--color-primary);
    border-bottom: 1px solid var(--color-primary);
    transition: color 180ms ease, border-color 180ms ease;
  }
  .legal-content :global(a:hover) {
    color: var(--color-accent-dark);
    border-bottom-color: var(--color-accent-dark);
  }

  .legal-content :global(.legal-note) {
    padding: 1.25rem 1.5rem;
    background: var(--color-accent-light);
    border-left: 3px solid var(--color-accent);
    margin-block: 1.75rem;
    font-size: 0.95rem;
  }

  .legal-content :global(address) {
    font-style: normal;
    margin-bottom: 1rem;
    line-height: 1.7;
    padding-left: 1rem;
    border-left: 1px solid var(--color-border);
  }
</style>
