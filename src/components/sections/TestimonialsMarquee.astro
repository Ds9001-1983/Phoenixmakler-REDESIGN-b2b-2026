---
// Sektion 6: Testimonials Marquee (SM-07)
const testimonials = [
  { quote: 'Nach 12 Jahren Pool endlich ein Verbund, in dem ich als Unternehmer gesehen werde.', name: 'Andreas K.', role: 'Makler aus Hannover' },
  { quote: 'Transparente Courtagen und ein Team, das tatsächlich erreichbar ist. Selten geworden.', name: 'Sabine M.', role: 'Maklerin aus Leipzig' },
  { quote: 'Die digitalen Prozesse haben mir Woche für Woche Zeit geschenkt.', name: 'Tim L.', role: 'Makler aus München' },
  { quote: 'Ich bin unabhängig geblieben — aber nicht mehr allein.', name: 'Claudia R.', role: 'Maklerin aus Bremen' },
  { quote: 'Was mich überzeugt hat? Kein Verkaufsdruck. Nur Antworten.', name: 'Martin S.', role: 'Makler aus Köln' },
];
---

<section class="testimonials">
  <div class="testimonials__header">
    <span class="testimonials__caption">Stimmen aus dem Verbund</span>
    <h2 class="testimonials__title">Was <em>unsere Makler</em> sagen.</h2>
  </div>

  <div class="testimonials__marquee" data-marquee data-marquee-speed="30" data-marquee-pause="true">
    <div class="marquee-track">
      {[...testimonials, ...testimonials].map((t) => (
        <figure class="testimonial-card">
          <svg class="testimonial-card__quote" width="36" height="28" viewBox="0 0 36 28" fill="none" aria-hidden="true">
            <path d="M0 28V17.5C0 12.6667 1.16667 8.5 3.5 5C5.83333 1.5 9.16667 -0.166667 13.5 0L14.5 3.5C11.8333 3.66667 9.83333 4.83333 8.5 7C7.16667 9 6.5 11.5 6.5 14.5H14V28H0ZM21.5 28V17.5C21.5 12.6667 22.6667 8.5 25 5C27.3333 1.5 30.6667 -0.166667 35 0L36 3.5C33.3333 3.66667 31.3333 4.83333 30 7C28.6667 9 28 11.5 28 14.5H35.5V28H21.5Z" fill="currentColor"/>
          </svg>
          <blockquote class="testimonial-card__quote-text">{t.quote}</blockquote>
          <figcaption class="testimonial-card__caption">
            <span class="testimonial-card__name">{t.name}</span>
            <span class="testimonial-card__role">{t.role}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    padding-block: clamp(5rem, 10vh, 8rem);
    background: var(--color-bg);
    overflow: hidden;
  }
  .testimonials__header {
    max-width: var(--content-max-width);
    margin: 0 auto 3rem;
    padding-inline: var(--padding-x);
  }
  .testimonials__caption {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
    margin-bottom: 1rem;
  }
  .testimonials__title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.025em;
    max-width: 20ch;
    color: var(--color-ink);
    margin: 0;
    font-variation-settings: 'opsz' 144, 'SOFT' 75;
  }
  .testimonials__title em {
    font-style: italic;
    font-weight: 300;
    color: var(--color-accent);
  }

  .testimonials__marquee {
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent, black 6%, black 94%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, black 6%, black 94%, transparent);
  }
  .marquee-track {
    display: flex;
    gap: 1.5rem;
    width: fit-content;
    will-change: transform;
  }

  .testimonial-card {
    flex: 0 0 clamp(320px, 32vw, 460px);
    padding: 2.25rem 2rem;
    background: var(--color-bg-warm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    min-height: 16rem;
  }
  .testimonial-card__quote {
    color: var(--color-accent);
    opacity: 0.6;
  }
  .testimonial-card__quote-text {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 400;
    line-height: 1.35;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    margin: 0;
    font-variation-settings: 'opsz' 72;
  }
  .testimonial-card__caption {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .testimonial-card__name {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-ink);
  }
  .testimonial-card__role {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }
</style>
