---
// Registrierungs-Formular "Partner werden"
// Submit geht an /api/partner-werden → Professional.Works CRM (status_id=3 storniert).
---

<section class="mform" id="partner-werden">
  <div class="mform__container">
    <div class="mform__head">
      <span class="mform__caption">Jetzt loslegen</span>
      <h2 class="mform__title">Deine Partnerschaft<br/><em>beginnt hier.</em></h2>
      <p class="mform__lead">
        Trag deine Daten ein — wir melden uns persönlich bei dir.
        Kein Automat, kein Callcenter. Torsten oder Lothar am Telefon, in der Regel innerhalb von zwei Werktagen.
      </p>
    </div>

    <p class="mform__required-hint" id="mform-req-hint">
      Mit <span aria-hidden="true">*</span> markierte Felder sind Pflichtfelder.
    </p>

    <form class="mform__form" data-registrierung novalidate data-reveal aria-label="Registrierungs-Formular fuer Maklerpartnerschaft" aria-describedby="mform-req-hint">
      <div class="mform__row">
        <div class="mform__field">
          <label for="anrede">Anrede *</label>
          <select id="anrede" name="anrede" required>
            <option value="">Bitte wählen</option>
            <option value="frau">Frau</option>
            <option value="herr">Herr</option>
            <option value="divers">Divers</option>
          </select>
        </div>
      </div>

      <div class="mform__row mform__row--2">
        <div class="mform__field">
          <label for="vorname">Vorname *</label>
          <input type="text" id="vorname" name="vorname" autocomplete="given-name" required />
        </div>
        <div class="mform__field">
          <label for="nachname">Nachname *</label>
          <input type="text" id="nachname" name="nachname" autocomplete="family-name" required />
        </div>
      </div>

      <div class="mform__row">
        <div class="mform__field">
          <label for="strasse">Straße &amp; Hausnummer *</label>
          <input type="text" id="strasse" name="strasse" autocomplete="street-address" required />
        </div>
      </div>

      <div class="mform__row mform__row--2">
        <div class="mform__field">
          <label for="plz">PLZ *</label>
          <input type="text" id="plz" name="plz" autocomplete="postal-code" inputmode="numeric" pattern="[0-9]{5}" required />
        </div>
        <div class="mform__field">
          <label for="ort">Ort *</label>
          <input type="text" id="ort" name="ort" autocomplete="address-level2" required />
        </div>
      </div>

      <div class="mform__row mform__row--2">
        <div class="mform__field">
          <label for="telefon">Telefon *</label>
          <input type="tel" id="telefon" name="telefon" autocomplete="tel" required />
        </div>
        <div class="mform__field">
          <label for="email">E-Mail *</label>
          <input type="email" id="email" name="email" autocomplete="email" required />
        </div>
      </div>

      <div class="mform__row mform__row--2">
        <div class="mform__field">
          <label for="geburtsdatum">Geburtsdatum *</label>
          <input type="date" id="geburtsdatum" name="geburtsdatum" required />
        </div>
        <div class="mform__field">
          <label for="nationalitaet">Nationalität *</label>
          <select id="nationalitaet" name="nationalitaet" required>
            <option value="">Bitte wählen</option>
            <option value="DE">Deutschland</option>
            <option value="AT">Österreich</option>
            <option value="CH">Schweiz</option>
            <option value="other">Andere</option>
          </select>
        </div>
      </div>

      <div class="mform__row">
        <div class="mform__field">
          <label for="ihk">IHK-Vermittlerregisternummer <span class="mform__optional">(optional)</span></label>
          <input type="text" id="ihk" name="ihk" />
        </div>
      </div>

      <div class="mform__checks">
        <label class="mform__check">
          <input type="checkbox" name="datenschutz" required />
          <span>Ich habe die <a href="/datenschutz">Datenschutzerklärung</a> gelesen und stimme zu. *</span>
        </label>
        <label class="mform__check">
          <input type="checkbox" name="kontakt_ok" />
          <span>Ich möchte von Phönix kontaktiert werden.</span>
        </label>
      </div>

      <div class="mform__hp" aria-hidden="true">
        <label>Bitte leer lassen<input type="text" name="_hp" tabindex="-1" autocomplete="off" /></label>
      </div>

      <div class="mform__submit">
        <button type="submit" class="btn btn-accent btn-lg" data-magnetic data-cursor-label="Absenden">
          <span data-submit-label>Jetzt Partner werden</span>
          <svg width="18" height="14" viewBox="0 0 18 14" fill="none" aria-hidden="true"><path d="M1 7h15M12 1l5 6-5 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <p class="mform__hint">
          Wir prüfen deine Bewerbung im Backoffice und melden uns persönlich.
          Deine Daten werden verschlüsselt direkt an Phönix übertragen.
        </p>
      </div>

      <div class="mform__success" data-form-success role="status" aria-live="polite" hidden>
        <h3>Bewerbung eingegangen!</h3>
        <p>
          Danke — Torsten oder Lothar prüfen deine Daten und melden sich persönlich
          bei dir, in der Regel innerhalb von zwei Werktagen.
        </p>
      </div>

      <div class="mform__error" data-form-error role="alert" hidden>
        <h3>Da ist etwas schiefgelaufen.</h3>
        <p data-form-error-msg>Bitte versuch es in einem Moment noch einmal — oder schreib uns direkt an
          <a href="mailto:info@phoenix-maklerverbund.de">info@phoenix-maklerverbund.de</a>
          oder ruf <a href="tel:+4926346598580">02634 659858-0</a> an.</p>
      </div>
    </form>
  </div>
</section>

<style>
  .mform {
    padding-block: clamp(5rem, 10vh, 8rem);
    background: var(--color-bg-warm);
    color: var(--color-ink);
  }
  .mform__container {
    max-width: 820px;
    margin-inline: auto;
    padding-inline: var(--padding-x);
  }
  .mform__head {
    text-align: center;
    margin-bottom: clamp(3rem, 6vh, 4rem);
  }
  .mform__caption {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
    margin-bottom: 1rem;
  }
  .mform__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    font-weight: 400;
    line-height: 1.0;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin: 0 auto 1.5rem;
    max-width: 18ch;
    font-variation-settings: 'opsz' 144, 'SOFT' 100;
  }
  .mform__title em {
    font-style: italic;
    font-weight: 300;
    color: var(--color-accent);
  }
  .mform__lead {
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--color-text-muted);
    max-width: 54ch;
    margin: 0 auto;
  }

  .mform__required-hint {
    text-align: center;
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin: 0 auto 1.25rem;
    max-width: 54ch;
  }

  .mform__form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    background: #fff;
    padding: clamp(2rem, 4vw, 3rem);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    border: 1px solid var(--color-border);
  }

  .mform__row { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  .mform__row--2 { grid-template-columns: 1fr 1fr; }
  @media (max-width: 600px) {
    .mform__row--2 { grid-template-columns: 1fr; }
  }

  .mform__field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .mform__field label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--color-ink);
    font-weight: 500;
  }
  .mform__optional {
    color: var(--color-text-muted);
    font-weight: 400;
    letter-spacing: 0;
    text-transform: none;
  }
  .mform__field input,
  .mform__field select {
    padding: 0.85rem 1rem;
    font-size: 1rem;
    font-family: var(--font-body);
    background: #fff;
    border: 1.5px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    color: var(--color-ink);
    transition: border-color 180ms ease, box-shadow 180ms ease;
  }
  .mform__field input:focus,
  .mform__field select:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(184,134,91,0.18);
  }

  .mform__checks {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding-top: 0.5rem;
  }
  .mform__check {
    display: flex;
    gap: 0.75rem;
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--color-text-muted);
    cursor: pointer;
  }
  .mform__check input[type="checkbox"] {
    margin-top: 0.2rem;
    accent-color: var(--color-accent);
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }
  .mform__check a {
    color: var(--color-accent-dark);
    border-bottom: 1px solid var(--color-accent-light);
  }
  .mform__check a:hover { border-bottom-color: var(--color-accent-dark); }

  .mform__submit {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
    padding-top: 0.5rem;
  }
  .mform__hint {
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--color-text-muted);
    max-width: 58ch;
    margin: 0;
  }

  .mform__success,
  .mform__error {
    text-align: center;
    padding: 2rem;
    border-radius: var(--radius-md);
    color: var(--color-ink);
  }
  .mform__success { background: var(--color-accent-light); }
  .mform__error { background: #fde7e7; border: 1px solid #f5b5b5; }
  .mform__success h3,
  .mform__error h3 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--color-ink);
    margin: 0 0 0.5rem;
  }
  .mform__hp {
    position: absolute;
    left: -10000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-registrierung]');
  const success = document.querySelector<HTMLElement>('[data-form-success]');
  const error = document.querySelector<HTMLElement>('[data-form-error]');
  const errorMsg = document.querySelector<HTMLElement>('[data-form-error-msg]');
  const submitLabel = document.querySelector<HTMLElement>('[data-submit-label]');

  const showError = (msg?: string) => {
    if (success) success.hidden = true;
    if (errorMsg && msg) errorMsg.textContent = msg;
    if (error) {
      error.hidden = false;
      error.setAttribute('tabindex', '-1');
      error.scrollIntoView({ behavior: 'smooth', block: 'center' });
      error.focus();
    }
  };

  const showSuccess = () => {
    form!.style.display = 'none';
    if (success) {
      success.hidden = false;
      success.setAttribute('tabindex', '-1');
      success.scrollIntoView({ behavior: 'smooth', block: 'center' });
      success.focus();
    }
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.reportValidity()) return;
    if (error) error.hidden = true;

    const fd = new FormData(form);
    const payload: Record<string, unknown> = {};
    for (const [k, v] of fd.entries()) {
      payload[k] = v instanceof File ? '' : v;
    }
    payload.datenschutz = fd.get('datenschutz') === 'on';
    payload.kontakt_ok = fd.get('kontakt_ok') === 'on';

    const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const orig = submitLabel?.textContent ?? 'Jetzt Partner werden';
    if (submitBtn) submitBtn.disabled = true;
    if (submitLabel) submitLabel.textContent = 'Wird gesendet …';

    try {
      const res = await fetch('/api/partner-werden', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (res.ok) {
        showSuccess();
        return;
      }

      let detail: { error?: string } = {};
      try { detail = await res.json(); } catch {}

      if (res.status === 409) {
        showError('Mit dieser E-Mail-Adresse besteht bereits ein Eintrag. Bitte ruf uns an.');
      } else if (res.status === 422) {
        showError('Bitte prüfe deine Eingaben — eines der Felder wurde abgelehnt.');
      } else {
        showError();
      }
      console.error('Submit failed', res.status, detail);
    } catch (err) {
      console.error('Network error', err);
      showError();
    } finally {
      if (submitBtn) submitBtn.disabled = false;
      if (submitLabel) submitLabel.textContent = orig;
    }
  });
</script>
