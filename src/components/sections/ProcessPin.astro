---
// Sektion 5: Prozess "Makler werden"
// Pin-Section (SM-03) mit 4 Schritten + Scroll-Progress-Number (SM-14)
const steps = [
  {
    num: '01',
    title: 'Kennenlernen',
    body: 'Ein Call, ein ehrliches Gespräch. Du erzählst, wo du stehst. Wir erklären, was wir anders machen. Keine Verkaufspräsentation.',
  },
  {
    num: '02',
    title: 'Prüfung & Entscheidung',
    body: 'Wir prüfen deine Lizenz, du prüfst unseren Verbund. Beide Seiten sagen bewusst ja — oder lassen es.',
  },
  {
    num: '03',
    title: 'Anbindung & Tools',
    body: 'CRM-Zugang, Pool-Courtagen, digitale Prozesse. In zwei Wochen bist du arbeitsfähig.',
  },
  {
    num: '04',
    title: 'Wachsen mit Rückendeckung',
    body: 'Mentoring, Leads aus dem Maklerfinder, gemeinsame Aktionen. Du bist unabhängig — aber nie allein.',
  },
];
---

<section class="process" data-pin data-pin-length="4">
  <div class="process__container">
    <div class="process__left">
      <span class="process__caption">Wie's läuft</span>
      <h2 class="process__title">In <em>vier Schritten</em><br/>vom Erstgespräch<br/>zum Makler im Verbund.</h2>
      <div class="process__indicator">
        <span class="process__indicator-num" data-pin-number>01</span>
        <span class="process__indicator-total">/ 04</span>
      </div>
      <div class="process__progress">
        <div class="process__progress-bar" data-pin-progress></div>
      </div>
      <div class="process__scroll-hint" aria-hidden="true">
        <span class="process__scroll-text">
          <span class="process__scroll-eyebrow">Weiterscrollen</span>
          <span class="process__scroll-sub">um die nächsten Schritte zu sehen</span>
        </span>
        <span class="process__scroll-arrow">
          <svg width="22" height="32" viewBox="0 0 22 32" fill="none">
            <path d="M11 2 V28 M2 19 L11 28 L20 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </div>
    </div>

    <div class="process__right">
      {steps.map((step) => (
        <div class="pin-step">
          <div class="process__step-num">{step.num}</div>
          <h3 class="process__step-title">{step.title}</h3>
          <p class="process__step-body">{step.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process {
    position: relative;
    min-height: 100vh;
    background: var(--color-bg-warm);
    color: var(--color-ink);
    overflow: hidden;
  }
  .process__container {
    position: relative;
    min-height: 100vh;
    max-width: var(--content-max-width);
    margin-inline: auto;
    padding: clamp(4rem, 8vh, 6rem) var(--padding-x);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }

  .process__left {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  .process__caption {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
  }
  .process__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin: 0;
    font-variation-settings: 'opsz' 144, 'SOFT' 75;
  }
  .process__title em {
    font-style: italic;
    font-weight: 300;
    color: var(--color-accent);
  }

  .process__indicator {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    font-family: var(--font-display);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .process__indicator-num {
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: 300;
    color: var(--color-ink);
    font-variation-settings: 'opsz' 144;
  }
  .process__indicator-total {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  .process__progress {
    width: 220px;
    max-width: 100%;
    height: 1px;
    background: rgba(10,25,64,0.15);
    position: relative;
    overflow: hidden;
  }
  .process__progress-bar {
    position: absolute;
    inset: 0;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left center;
  }

  .process__scroll-hint {
    display: inline-flex;
    align-items: center;
    gap: 1.1rem;
    margin-top: 0.5rem;
    padding: 0.85rem 1.25rem;
    background: rgba(184, 134, 91, 0.1);
    border: 1px solid rgba(184, 134, 91, 0.35);
    border-radius: 999px;
    color: var(--color-accent-dark);
    transition: opacity 500ms ease, transform 500ms ease;
    align-self: flex-start;
  }
  .process__scroll-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }
  .process__scroll-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
  }
  .process__scroll-sub {
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin-top: 0.2rem;
    text-transform: none;
    letter-spacing: 0;
  }
  .process__scroll-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    animation: process-scroll-arrow 1.6s cubic-bezier(0.45, 0, 0.55, 1) infinite;
  }
  .process[data-pin-active="1"] .process__scroll-hint {
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
  }

  @keyframes process-scroll-arrow {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(8px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .process__scroll-arrow { animation: none; }
  }

  .process__right {
    position: relative;
    min-height: 22rem;
  }
  .pin-step {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding-left: 2rem;
    border-left: 1px solid rgba(10,25,64,0.1);
    will-change: transform, opacity;
  }
  .process__step-num {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    color: var(--color-accent-dark);
  }
  .process__step-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--color-ink);
  }
  .process__step-body {
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--color-text-muted);
    max-width: 42ch;
  }

  @media (max-width: 820px) {
    .process { min-height: auto; }
    .process__container {
      min-height: auto;
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding-block: clamp(3.5rem, 8vh, 5rem);
    }
    .process__left { gap: 1.5rem; }
    .process__indicator { display: none; }
    .process__progress { display: none; }
    .process__scroll-hint { display: none; }
    .process__right { min-height: auto; position: relative; display: grid; gap: 2.5rem; }
    .pin-step {
      position: relative;
      opacity: 1 !important;
      transform: none !important;
      padding-left: 1.25rem;
    }
  }
</style>
