---
// Schwerpunkte / Skills als Pill-Liste. Rendert nichts, wenn leer.
interface Props {
  skills: string[];
}
const { skills } = Astro.props;
---

{skills.length > 0 && (
  <section class="pskills section-sm bg-cream">
    <div class="container-narrow">
      <span class="eyebrow" data-reveal>Schwerpunkte</span>
      <ul class="pskills__list">
        {skills.map((s, i) => (
          <li class="pskills__pill" data-reveal data-reveal-delay={(i % 6) + 1}>{s}</li>
        ))}
      </ul>
    </div>
  </section>
)}

<style>
  .pskills__list {
    list-style: none;
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .pskills__pill {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.2rem;
    border-radius: 999px;
    background: #fff;
    border: 1px solid var(--color-accent-light);
    color: var(--color-accent-dark);
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    /* Längere Schwerpunkte (kurze Sätze) brechen sauber mehrzeilig um, statt aus dem
       Container zu laufen oder gekappt zu wirken. Kurze Tags bleiben einzeilige Pills. */
    max-width: min(100%, 46ch);
    line-height: 1.4;
    text-align: left;
    overflow-wrap: anywhere;
  }
</style>
