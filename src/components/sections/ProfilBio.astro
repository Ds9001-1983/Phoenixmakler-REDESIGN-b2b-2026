---
// Biografie-Block. bio ist Plain-Text (mehrzeilig) — Absätze an Leerzeilen/Zeilenumbrüchen.
interface Props {
  bio: string;
}
const { bio } = Astro.props;
const absaetze = bio
  .split(/\n{1,}/)
  .map((p) => p.trim())
  .filter(Boolean);
---

{absaetze.length > 0 && (
  <section class="pbio section" id="ueber-mich">
    <div class="container-narrow">
      <span class="eyebrow" data-reveal>Über mich</span>
      <div class="pbio__text">
        {absaetze.map((p, i) => (
          <p data-reveal data-reveal-delay={Math.min((i % 3) + 1, 3)}>{p}</p>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .pbio { background: var(--color-bg); }
  .pbio__text { margin-top: 1.5rem; display: flex; flex-direction: column; gap: 1.25rem; }
  /* Einheitliche, linksbündige Absätze — kein Sonderfall für den ersten Absatz. */
  .pbio__text p {
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: 400;
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 68ch;
  }
</style>
