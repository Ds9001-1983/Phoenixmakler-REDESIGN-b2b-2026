---
// Sektion 4: Produkt-Showcase
// Horizontal Scroll Pin (SM-08) mit 7 Produkt-Tiles
const products = [
  { slug: 'altersvorsorge', title: 'Altersvorsorge', teaser: 'Rente, die zu deinem Leben passt.', num: '01' },
  { slug: 'einkommenssicherung', title: 'Einkommenssicherung', teaser: 'Wenn Arbeit mal nicht geht.', num: '02' },
  { slug: 'zahnzusatzversicherung', title: 'Zahnzusatz', teaser: 'Für das Lächeln, das du willst.', num: '03' },
  { slug: 'krankenhauszusatzversicherung', title: 'Krankenhauszusatz', teaser: 'Chefarzt. Einzelzimmer. Ruhe.', num: '04' },
  { slug: 'haustier', title: 'Haustier', teaser: 'Weil Tierarztrechnungen nicht verhandeln.', num: '05' },
  { slug: 'haus-wohnen', title: 'Haus & Wohnen', teaser: 'Dein Zuhause, abgesichert.', num: '06' },
  { slug: 'vermoegensaufbau', title: 'Vermögensaufbau', teaser: 'Kleine Schritte, große Wirkung.', num: '07' },
];
---

<section class="products" data-hscroll>
  <div class="products__header">
    <div class="products__header-inner">
      <span class="products__caption">Unsere Produkte</span>
      <h2 class="products__title">Für <em>jede</em> Lebenslage<br/>den passenden Schutz.</h2>
      <p class="products__scroll-hint" aria-hidden="true">
        <span>Scrollen</span>
        <svg width="28" height="12" viewBox="0 0 28 12" fill="none"><path d="M1 6h24M21 1l5 5-5 5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </p>
    </div>
  </div>

  <div class="hscroll-track">
    {products.map((p) => (
      <a href={`/kunde/${p.slug}`} class="product-tile" data-cursor-label="Mehr zeigen">
        <div class="product-tile__num">{p.num}</div>
        <div class="product-tile__image">
          <div class="product-tile__placeholder" aria-hidden="true"></div>
        </div>
        <div class="product-tile__body">
          <h3 class="product-tile__title">{p.title}</h3>
          <p class="product-tile__teaser">{p.teaser}</p>
          <span class="product-tile__cta">
            Ansehen
            <svg width="20" height="14" viewBox="0 0 20 14" fill="none"><path d="M1 7h17M14 1l5 6-5 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .products {
    position: relative;
    background: var(--color-primary-dark);
    color: #fff;
    min-height: 100vh;
    overflow: hidden;
  }

  .products__header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 5;
    padding: clamp(3rem, 6vh, 5rem) var(--padding-x) 0;
    pointer-events: none;
  }
  .products__header-inner {
    max-width: var(--content-max-width);
    margin-inline: auto;
  }
  .products__caption {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }
  .products__title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1.0;
    letter-spacing: -0.025em;
    color: #fff;
    max-width: 18ch;
    margin: 0;
    font-variation-settings: 'opsz' 144, 'SOFT' 75;
  }
  .products__title em {
    font-style: italic;
    font-weight: 300;
    color: var(--color-accent);
  }
  .products__scroll-hint {
    margin-top: 2rem;
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
  }

  .hscroll-track {
    display: flex;
    gap: 2rem;
    align-items: center;
    min-height: 100vh;
    padding: 0 10vw;
    will-change: transform;
  }

  .product-tile {
    flex: 0 0 clamp(320px, 32vw, 480px);
    aspect-ratio: 4 / 5;
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: linear-gradient(165deg, #1a2a4e 0%, #0a1940 100%);
    color: #fff;
    text-decoration: none;
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: 1.75rem;
    border: 1px solid rgba(255,255,255,0.06);
    transition: transform 400ms cubic-bezier(0.16, 1, 0.3, 1), border-color 300ms ease;
  }
  .product-tile:hover {
    transform: translateY(-6px);
    border-color: var(--color-accent);
  }

  .product-tile__num {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    color: var(--color-accent);
  }
  .product-tile__image {
    position: relative;
    margin: -1.75rem -1.75rem 0;
  }
  .product-tile__placeholder {
    aspect-ratio: 4 / 3;
    background:
      radial-gradient(circle at 30% 30%, rgba(184,134,91,0.22), transparent 60%),
      radial-gradient(circle at 70% 75%, rgba(30,58,138,0.5), transparent 60%),
      linear-gradient(145deg, #0f2552 0%, #050d26 100%);
  }

  .product-tile__body {
    padding-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .product-tile__title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: #fff;
    margin: 0;
  }
  .product-tile__teaser {
    font-size: 0.94rem;
    line-height: 1.5;
    color: rgba(255,255,255,0.7);
    max-width: 28ch;
  }
  .product-tile__cta {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    transition: gap 300ms ease;
  }
  .product-tile:hover .product-tile__cta { gap: 0.85rem; }

  @media (max-width: 768px) {
    .products { min-height: auto; padding-bottom: 4rem; }
    .products__header { position: static; padding-bottom: 2rem; }
    .hscroll-track {
      flex-direction: column;
      min-height: auto;
      padding: 0 var(--padding-x);
      gap: 1.25rem;
    }
    .product-tile {
      flex: 1 1 auto;
      width: 100%;
      aspect-ratio: 3 / 4;
    }
  }
</style>
