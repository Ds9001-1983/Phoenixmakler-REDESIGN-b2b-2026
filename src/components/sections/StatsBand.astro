---
// Stats-Band (aus V3 übernommen, editorial aufgewertet)
// Trust-Zahlen: Jahre / Partner / inhabergeführt / MVP-Kosten
---

<section class="stats" aria-label="Phönix in Zahlen">
  <div class="stats__container">
    <div class="stats__item" data-reveal>
      <span class="stats__value"><span data-count="13" data-count-duration="1.4">0</span></span>
      <span class="stats__label">Jahre Erfahrung<br/>im Verbund</span>
    </div>
    <div class="stats__item" data-reveal data-reveal-delay="1">
      <span class="stats__value"><span data-count="120" data-count-duration="1.8">0</span>+</span>
      <span class="stats__label">Maklerinnen und Makler<br/>im Netzwerk</span>
    </div>
    <div class="stats__item" data-reveal data-reveal-delay="2">
      <span class="stats__value"><span data-count="100">0</span>%</span>
      <span class="stats__label">inhabergeführt<br/>und ungebunden</span>
    </div>
    <div class="stats__item" data-reveal data-reveal-delay="3">
      <span class="stats__value"><span data-count="180" data-count-duration="1.8">0</span>+</span>
      <span class="stats__label">Direktanbindungen<br/>in der Finanzbranche</span>
    </div>
  </div>
</section>

<style>
  .stats {
    padding-block: clamp(3rem, 7vh, 5rem);
    background: var(--color-bg);
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }
  .stats__container {
    max-width: var(--content-max-width);
    margin-inline: auto;
    padding-inline: var(--padding-x);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1.25rem, 3vw, 3rem);
    text-align: left;
  }
  .stats__item {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    position: relative;
  }
  .stats__item + .stats__item::before {
    content: '';
    position: absolute;
    left: calc(-1 * clamp(0.625rem, 1.5vw, 1.5rem));
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--color-line);
  }
  .stats__value {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    font-variation-settings: 'opsz' 144, 'SOFT' 75;
    font-variant-numeric: tabular-nums;
  }
  .stats__label {
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.4;
    color: var(--color-text-muted);
    font-weight: 400;
    letter-spacing: 0.01em;
  }

  @media (max-width: 820px) {
    .stats__container { grid-template-columns: repeat(2, 1fr); gap: 2rem 1.5rem; }
    .stats__item:nth-child(3)::before { display: none; }
  }
</style>
