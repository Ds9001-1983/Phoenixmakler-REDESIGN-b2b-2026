---
// Sektion 2: Hook Statement
// Mega-Typo (>200px) mit Scroll-Scrub-Reveal (SM-01 Split-Text)
---

<section class="hook">
  <div class="hook__container">
    <p class="hook__caption" data-reveal>Worum es geht</p>
    <h2 class="hook__text mega" data-split="words" data-split-stagger="0.07">
      Wir beraten nicht,
      <em>um zu verkaufen.</em>
      Wir beraten, weil wir dir <em>zuhören.</em>
    </h2>
  </div>
</section>

<style>
  .hook {
    padding-block: clamp(8rem, 16vh, 14rem);
    background: var(--color-bg-warm);
    color: var(--color-ink);
    overflow: hidden;
  }
  .hook__container {
    max-width: var(--content-max-width);
    margin-inline: auto;
    padding-inline: var(--padding-x);
  }
  .hook__caption {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
    margin-bottom: 2.5rem;
  }
  .hook__text {
    max-width: 18ch;
  }
  .hook__text em {
    font-style: italic;
    color: var(--color-accent);
    font-weight: 300;
  }

  @media (max-width: 720px) {
    .hook { padding-block: clamp(5rem, 10vh, 8rem); }
  }
</style>
