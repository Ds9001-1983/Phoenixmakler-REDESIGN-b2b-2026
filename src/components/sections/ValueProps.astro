---
const props = [
  {
    num: '01',
    title: 'Ungebunden & inhabergeführt – ohne fremde Kapitalinteressen',
    body: 'Keine Beteiligungen von Versicherern oder anonymen Finanzinvestoren. Du arbeitest mit einem Verbund, der ausschließlich seinen Maklern verpflichtet ist – nicht den Renditeerwartungen externer Geldgeber. Während sich Teile des Marktes zunehmend von Investorenkapital steuern lassen und immer neue Ertragsquellen suchen, halten wir unsere Strukturen bewusst schlank und unabhängig. So bleibt der Fokus dort, wo er hingehört: auf einer fairen Zusammenarbeit zwischen Makler, Kunde und Versicherern.',
  },
  {
    num: '02',
    title: 'Courtagevorteile, die spürbar sind.',
    body: 'Durch starke Sondervereinbarungen erhältst du Zugang zu attraktiven Konditionen und echten wirtschaftlichen Vorteilen.',
  },
  {
    num: '03',
    title: 'Sicher aufgestellt von Anfang an.',
    body: 'Mit rechtssicheren Rahmenbedingungen und klaren Prozessen begleiten wir dich verlässlich in die Ungebundenheit.',
  },
  {
    num: '04',
    title: 'Ein Verbund, der mitdenkt.',
    body: 'Persönlicher Austausch, kollegiales Wissen und operative Unterstützung machen den Unterschied im Alltag.',
  },
];
---

<section class="vprops">
  <div class="vprops__container">
    <div class="vprops__head">
      <span class="vprops__caption">Vier Gründe</span>
      <h2 class="vprops__title">Warum Makler bei <em>Phönix</em> werden.</h2>
    </div>

    <div class="vprops__grid">
      {props.map((p, i) => (
        <article
          class:list={['vprop', { 'vprop--lead': i === 0 }]}
          data-reveal
          data-reveal-delay={i + 1}
        >
          <span class="vprop__num">{p.num}</span>
          <h3 class="vprop__title">{p.title}</h3>
          <p class="vprop__body">{p.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .vprops {
    padding-block: clamp(5rem, 10vh, 8rem);
    background: var(--color-bg-warm);
    color: var(--color-ink);
  }
  .vprops__container {
    max-width: var(--content-max-width);
    margin-inline: auto;
    padding-inline: var(--padding-x);
  }
  .vprops__head {
    margin-bottom: clamp(3rem, 6vh, 5rem);
    max-width: 20ch;
  }
  .vprops__caption {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
    margin-bottom: 1rem;
  }
  .vprops__title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin: 0;
    font-variation-settings: 'opsz' 144, 'SOFT' 75;
  }
  .vprops__title em {
    font-style: italic;
    font-weight: 300;
    color: var(--color-accent);
  }

  .vprops__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(2rem, 4vw, 4rem);
  }

  .vprop {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(10,25,64,0.12);
  }
  .vprop--lead {
    grid-column: 1 / -1;
  }
  .vprop--lead .vprop__title {
    font-size: clamp(1.85rem, 3vw, 2.4rem);
    max-width: 28ch;
  }
  .vprop--lead .vprop__body {
    max-width: 78ch;
  }
  .vprop__num {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    color: var(--color-accent-dark);
  }
  .vprop__title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.2vw, 1.85rem);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0;
    font-variation-settings: 'opsz' 72;
  }
  .vprop__body {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 40ch;
  }

  @media (max-width: 820px) {
    .vprops__grid { grid-template-columns: 1fr; }
    .vprop--lead { grid-column: auto; }
  }
</style>
