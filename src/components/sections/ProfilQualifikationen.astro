---
// Ausbildung / Qualifikationen als nummerierte Editorial-Liste. Rendert nichts, wenn leer.
interface Props {
  qualifikationen: string[];
}
const { qualifikationen } = Astro.props;
const pad = (n: number) => String(n).padStart(2, '0');
---

{qualifikationen.length > 0 && (
  <section class="pqual section">
    <div class="container-narrow">
      <span class="eyebrow" data-reveal>Qualifikationen</span>
      <ol class="pqual__list">
        {qualifikationen.map((q, i) => (
          <li class="pqual__item" data-reveal data-reveal-delay={(i % 4) + 1}>
            <span class="pqual__num">{pad(i + 1)}</span>
            <span class="pqual__text">{q}</span>
          </li>
        ))}
      </ol>
    </div>
  </section>
)}

<style>
  .pqual { background: var(--color-bg); }
  /* margin-top an die übrigen Sektionen angeglichen (1.5rem); Breite folgt dem Container. */
  .pqual__list { list-style: none; margin-top: 1.5rem; display: grid; gap: 0; }
  .pqual__item {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    padding: 1.25rem 0;
    border-top: 1px solid var(--color-border);
  }
  .pqual__item:last-child { border-bottom: 1px solid var(--color-border); }
  .pqual__num {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-accent-dark);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }
  .pqual__text {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.8vw, 1.4rem);
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-ink);
  }
</style>
