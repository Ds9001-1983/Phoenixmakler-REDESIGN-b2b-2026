---
interface Props {
  name: string;
  text: string;
  logo: string;
  url: string;
}
const { name, text, logo, url } = Astro.props;
---

<article class="product-block">
  <div class="product-logo">
    <img src={logo} alt={`${name} Logo`} loading="lazy" />
  </div>
  <div class="product-body">
    <h3>{name}</h3>
    <p>{text}</p>
  </div>
  <div class="product-cta">
    <a href={url} class="btn btn-primary" target="_blank" rel="noopener">
      Berechnen →
    </a>
  </div>
</article>

<style>
  .product-block {
    display: grid;
    grid-template-columns: 180px 1fr auto;
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: center;
    padding: clamp(1.75rem, 3vw, 2.5rem);
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: border-color 260ms ease, box-shadow 260ms ease, transform 260ms var(--ease-out);
  }

  .product-block:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  @media (max-width: 900px) {
    .product-block {
      grid-template-columns: 140px 1fr;
      grid-template-rows: auto auto;
    }
    .product-cta { grid-column: 1 / -1; justify-self: start; }
  }

  @media (max-width: 560px) {
    .product-block { grid-template-columns: 1fr; padding: 1.5rem; }
    .product-cta { grid-column: 1; }
  }

  .product-logo {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    min-height: 80px;
  }

  .product-logo img {
    max-width: 140px;
    max-height: 70px;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .product-body h3 {
    margin-bottom: 0.6rem;
    color: var(--color-ink);
    font-size: clamp(1.2rem, 2vw, 1.4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .product-body p {
    color: var(--color-text-muted);
    font-size: 0.96rem;
    line-height: 1.55;
    max-width: 54ch;
  }
</style>
