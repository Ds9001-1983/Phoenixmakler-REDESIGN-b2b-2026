---
interface Props {
  name: string;
  text: string;
  logo: string;
  url: string;
}
const { name, text, logo, url } = Astro.props;
---

<article class="product-block">
  <div class="product-logo">
    <img src={logo} alt={`${name} Logo`} loading="lazy" />
  </div>
  <div class="product-body">
    <h3>{name}</h3>
    <p>{text}</p>
    <a href={url} class="btn btn-primary" target="_blank" rel="noopener">
      Berechnen & abschließen <span aria-hidden="true">→</span>
    </a>
  </div>
</article>

<style>
  .product-block {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2rem;
    align-items: center;
    padding: 2rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  @media (max-width: 640px) {
    .product-block {
      grid-template-columns: 1fr;
      gap: 1.25rem;
      padding: 1.5rem;
    }
  }

  .product-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 120px;
  }

  .product-logo img {
    max-width: 160px;
    max-height: 100px;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .product-body h3 {
    margin-bottom: 0.5rem;
    color: var(--color-primary-dark);
  }

  .product-body p {
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }
</style>
