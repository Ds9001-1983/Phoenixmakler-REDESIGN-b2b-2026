---
import navigation from '../data/navigation.json';

const { pathname } = Astro.url;
const isActive = (href: string) => pathname === href || (href !== '/' && pathname.startsWith(href));
---

<header class="site-header" data-header>
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="Phönix Maklerverbund – Startseite">
      <img src="/images/logo.png" alt="Phönix Maklerverbund" width="180" height="48" />
    </a>

    <button
      class="burger"
      type="button"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="primary-nav"
      data-burger
    >
      <span></span><span></span>
    </button>

    <nav id="primary-nav" class="nav" aria-label="Hauptnavigation" data-nav>
      <ul class="nav-list">
        {navigation.primary.map((item) => (
          <li>
            <a href={item.href} class:list={['nav-link', { active: isActive(item.href) }]}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      <div class="nav-cta">
        <a href="/kunde" class="nav-cta-link">Ich bin Kunde</a>
        <a href="/makler-werden" class="btn btn-primary">Partner werden</a>
      </div>
    </nav>
  </div>
</header>

<a href="/makler-werden" class="mobile-sticky-cta">Partner werden</a>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: saturate(180%) blur(14px);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    border-bottom: 1px solid transparent;
    transition: border-color 300ms ease, background-color 300ms ease;
  }

  .site-header.is-scrolled {
    border-bottom-color: var(--color-border);
    background: rgba(255, 255, 255, 0.92);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding-block: 1.05rem;
  }

  .logo { flex-shrink: 0; display: block; }
  .logo img { height: 36px; width: auto; }

  .nav {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .nav-list {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .nav-link {
    position: relative;
    font-size: 0.93rem;
    font-weight: 500;
    color: var(--color-ink);
    padding: 0.45rem 0;
    transition: color 160ms ease;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1.5px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 400ms var(--ease-out);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .nav-cta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-cta-link {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
    transition: color 180ms ease;
  }
  .nav-cta-link:hover { color: var(--color-primary); }

  .btn {
    padding: 0.55rem 1.15rem;
    font-size: 0.9rem;
    min-height: 40px;
  }

  .burger {
    display: none;
    background: transparent;
    border: 0;
    padding: 0.5rem;
    cursor: pointer;
    min-width: var(--min-touch-target);
    min-height: var(--min-touch-target);
    flex-direction: column;
    gap: 6px;
    align-items: center;
    justify-content: center;
  }

  .burger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--color-ink);
    transition: transform 280ms var(--ease-out);
  }

  .burger[aria-expanded="true"] span:nth-child(1) { transform: translateY(4px) rotate(45deg); }
  .burger[aria-expanded="true"] span:nth-child(2) { transform: translateY(-4px) rotate(-45deg); }

  .mobile-sticky-cta { display: none; }

  @media (max-width: 959px) {
    .burger { display: flex; }

    .nav {
      position: fixed;
      inset: 64px 0 0 0;
      flex-direction: column;
      align-items: stretch;
      justify-content: flex-start;
      background: #fff;
      padding: 3rem var(--padding-x) 8rem;
      gap: 2rem;
      overflow-y: auto;
      transform: translateX(100%);
      transition: transform 360ms var(--ease-out);
    }

    .nav[data-open="true"] { transform: translateX(0); }

    .nav-list {
      flex-direction: column;
      gap: 0;
    }

    .nav-list li {
      border-bottom: 1px solid var(--color-border);
    }

    .nav-link {
      display: block;
      padding: 1.25rem 0;
      font-size: 1.25rem;
      font-weight: 600;
    }

    .nav-cta {
      flex-direction: column;
      gap: 1rem;
      margin-top: 1rem;
      align-items: stretch;
    }

    .nav-cta .btn { width: 100%; }

    .mobile-sticky-cta {
      display: flex;
      align-items: center;
      justify-content: center;
      position: fixed;
      bottom: 1rem;
      left: 1rem;
      right: 1rem;
      z-index: 90;
      padding: 1rem;
      background: var(--color-ink);
      color: #fff;
      font-weight: 600;
      border-radius: 999px;
      box-shadow: var(--shadow-lg);
    }
  }
</style>

<script>
  const burger = document.querySelector<HTMLButtonElement>('[data-burger]');
  const nav = document.querySelector<HTMLElement>('[data-nav]');
  const header = document.querySelector<HTMLElement>('[data-header]');

  burger?.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    burger.setAttribute('aria-label', open ? 'Menü öffnen' : 'Menü schließen');
    nav?.setAttribute('data-open', String(!open));
    document.body.style.overflow = !open ? 'hidden' : '';
  });

  document.querySelectorAll('[data-nav] a').forEach((link) => {
    link.addEventListener('click', () => {
      burger?.setAttribute('aria-expanded', 'false');
      nav?.setAttribute('data-open', 'false');
      document.body.style.overflow = '';
    });
  });

  window.addEventListener('scroll', () => {
    header?.classList.toggle('is-scrolled', window.scrollY > 20);
  }, { passive: true });
</script>
