---
interface Props {
  headline: string;
  url: string;
  image?: string;
}
const { headline, url, image } = Astro.props;
---

<a href={url} class="teaser-card" target="_blank" rel="noopener">
  {image && (
    <div class="teaser-image">
      <img src={image} alt="" loading="lazy" />
    </div>
  )}
  <div class="teaser-body">
    <h3>{headline}</h3>
    <span class="teaser-arrow">Mehr erfahren →</span>
  </div>
</a>

<style>
  .teaser-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    color: var(--color-ink);
    transition: border-color 260ms ease, transform 260ms var(--ease-out), box-shadow 260ms ease;
    height: 100%;
  }

  .teaser-card:hover,
  .teaser-card:focus-visible {
    border-color: var(--color-border-strong);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .teaser-image {
    aspect-ratio: 16/10;
    overflow: hidden;
    background: var(--color-bg-soft);
  }

  .teaser-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .teaser-body {
    padding: 1.5rem 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
    justify-content: space-between;
  }

  .teaser-body h3 {
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.015em;
  }

  .teaser-arrow {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
    align-self: flex-start;
    transition: transform 240ms var(--ease-out);
  }

  .teaser-card:hover .teaser-arrow { transform: translateX(4px); }
</style>
