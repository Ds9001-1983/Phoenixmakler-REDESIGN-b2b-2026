---
// SM-15: Preloader mit echtem Progress
// Nutzt window.load + Bild-Preloading für realistischen Fortschritt
---

<div class="preloader" id="preloader" aria-hidden="true">
  <div class="preloader__inner">
    <div class="preloader__brand">Phönix</div>
    <div class="preloader__bar">
      <div class="preloader__bar-fill" id="preloader-fill"></div>
    </div>
    <div class="preloader__count">
      <span id="preloader-count">0</span><span class="preloader__unit">%</span>
    </div>
  </div>
</div>

<style>
  .preloader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--color-primary-dark);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 600ms cubic-bezier(0.7, 0, 0.2, 1), visibility 600ms;
    will-change: opacity;
  }
  .preloader.is-done {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }
  .preloader__inner {
    width: min(420px, 80vw);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }
  .preloader__brand {
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(3rem, 6vw, 4.5rem);
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--color-accent);
    font-variation-settings: 'opsz' 144, 'SOFT' 100;
  }
  .preloader__bar {
    width: 100%;
    height: 1px;
    background: rgba(255, 255, 255, 0.12);
    overflow: hidden;
    position: relative;
  }
  .preloader__bar-fill {
    position: absolute;
    inset: 0;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 220ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .preloader__count {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.5);
    font-variant-numeric: tabular-nums;
  }
  .preloader__unit { margin-left: 0.1em; }

  @media (prefers-reduced-motion: reduce) {
    .preloader__bar-fill { transition: none; }
  }
</style>

<script is:inline>
  // INLINE (nicht gebündelt!) — läuft sofort beim Parsen, unabhängig vom großen
  // JS-Bundle. Frühere Versionen hingen an DOMContentLoaded/window.load; da deferred
  // Module DOMContentLoaded blockieren, verzögerte das den Preloader-Ausblend und
  // damit das LCP massiv. Jetzt: reiner Timer (~800 ms), dann ausblenden.
  (function () {
    var el = document.getElementById('preloader');
    if (!el) return;
    var fill = document.getElementById('preloader-fill');
    var countEl = document.getElementById('preloader-count');
    var done = function () {
      el.classList.add('is-done');
      document.documentElement.classList.add('preloader-done');
      setTimeout(function () { try { el.remove(); } catch (e) {} }, 650);
    };
    var reduced = document.documentElement.getAttribute('data-a11y-motion') === 'reduced';
    if (reduced) { done(); return; }

    var start = performance.now();
    var minDuration = 800;
    (function tick() {
      var p = Math.min((performance.now() - start) / minDuration, 1);
      if (fill) fill.style.transform = 'scaleX(' + p + ')';
      if (countEl) countEl.textContent = String(Math.floor(p * 100));
      if (p < 1) requestAnimationFrame(tick);
      else done();
    })();
  })();
</script>
