---
import navigation from '../data/navigation.json';
const k = navigation.kontakt;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <img src="/images/logo.png" alt="Phönix Maklerverbund" width="180" height="48" class="footer-logo" />
        <p class="footer-tagline">
          <em>Ungebunden.</em> Inhabergeführt. Seit 2012.
        </p>
        <address class="footer-address">
          {k.firma}<br />
          {k.strasse}<br />
          {k.plz_ort}
        </address>
        <div class="footer-contact">
          <a href={k.telefon_href}>{k.telefon}</a>
          <a href={`mailto:${k.email}`}>{k.email}</a>
        </div>
      </div>

      <div class="footer-cols">
        <div>
          <h3 class="footer-heading">Leistungen</h3>
          <ul class="footer-list">
            {navigation.footer.leistungen.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </div>

        <div>
          <h3 class="footer-heading">Phönix</h3>
          <ul class="footer-list">
            <li><a href="/ueber-uns">Über uns</a></li>
            <li><a href="/makler-werden">Partner werden</a></li>
            <li><a href="/makler-suche">Maklerfinder</a></li>
            <li><a href="/kontakt">Kontakt</a></li>
          </ul>
        </div>

        <div>
          <h3 class="footer-heading">Rechtliches</h3>
          <ul class="footer-list">
            {navigation.footer.rechtlich.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">© {year} Phönix Maklerverbund GmbH</p>
      <p class="footer-credit">
        Webseite von <a href="https://superbrand.marketing" target="_blank" rel="noopener">Superbrand.marketing</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-dark);
    color: rgba(250, 247, 242, 0.72);
    padding-block: clamp(4rem, 7vw, 6rem) 2rem;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.3fr 2fr;
    gap: clamp(2rem, 6vw, 6rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
    border-bottom: 1px solid rgba(250, 247, 242, 0.1);
  }

  @media (max-width: 900px) {
    .footer-top { grid-template-columns: 1fr; gap: 3rem; }
  }

  .footer-logo {
    filter: brightness(0) invert(1);
    height: 40px;
    width: auto;
    margin-bottom: 1.5rem;
  }

  .footer-tagline {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-cream);
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }

  .footer-tagline em {
    font-style: italic;
    color: var(--color-accent);
  }

  .footer-address {
    font-style: normal;
    line-height: 1.7;
    color: rgba(250, 247, 242, 0.7);
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-contact a {
    color: var(--color-cream);
    font-size: 0.95rem;
    border-bottom: 1px solid transparent;
    transition: border-color 220ms ease, color 220ms ease;
    width: max-content;
  }

  .footer-contact a:hover {
    border-bottom-color: var(--color-accent);
    color: var(--color-accent);
  }

  .footer-cols {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2.5rem;
  }

  @media (max-width: 640px) {
    .footer-cols { grid-template-columns: 1fr 1fr; gap: 2rem; }
  }

  .footer-heading {
    font-family: var(--font-body);
    color: var(--color-cream);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .footer-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    font-size: 0.95rem;
  }

  .footer-list a {
    color: rgba(250, 247, 242, 0.7);
    transition: color 220ms ease;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .footer-list a::before {
    content: '';
    width: 8px;
    height: 1px;
    background: var(--color-accent);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 220ms ease, transform 220ms var(--ease-out);
  }

  .footer-list a:hover {
    color: var(--color-cream);
  }

  .footer-list a:hover::before {
    opacity: 1;
    transform: translateX(0);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 2rem;
    flex-wrap: wrap;
    font-size: 0.82rem;
    color: rgba(250, 247, 242, 0.5);
  }

  .footer-credit a {
    color: var(--color-accent);
    border-bottom: 1px solid transparent;
    transition: border-color 220ms ease;
  }

  .footer-credit a:hover {
    border-bottom-color: var(--color-accent);
  }
</style>
