# Tracking — datenschutzfreundlich, ohne Cookies (DSGVO-konform, kein Consent-Banner nötig).
# Eine der beiden Optionen aktivieren, in Vercel unter Settings → Environment Variables setzen.

# Option A: Plausible (gehostet oder self-hosted)
PUBLIC_PLAUSIBLE_DOMAIN=phoenix-maklerverbund.de

# Option B: Umami (self-hosted, kostenlos)
# PUBLIC_UMAMI_URL=https://analytics.phoenix-maklerverbund.de/script.js
# PUBLIC_UMAMI_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
