# Tracking — datenschutzfreundlich, ohne Cookies (DSGVO-konform, kein Consent-Banner nötig).
# Eine der beiden Optionen aktivieren, in Vercel unter Settings → Environment Variables setzen.

# Option A: Plausible (gehostet oder self-hosted)
PUBLIC_PLAUSIBLE_DOMAIN=phoenix-maklerverbund.de

# Option B: Umami (self-hosted, kostenlos)
# PUBLIC_UMAMI_URL=https://analytics.phoenix-maklerverbund.de/script.js
# PUBLIC_UMAMI_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Professional.Works CRM (Phoenix-Maklerverbund). Server-only, NICHT mit PUBLIC_ präfixen.
# Bewerber aus dem "Partner werden"-Form werden hier mit status_id=3 (storniert) angelegt.
PW_API_BASE=https://api.professional.works
PW_USER_SLUG=me
PW_BEARER_TOKEN=
PW_DEFAULT_AGENCY_ID=3844

# Onboarding-Mail (an Phoenix bei jeder Bewerbung) und Trigger-Link.
# SMTP-Account: dedizierte Adresse "neuerpartner@phoenix-maklerverbund.de" bei Goneo.
# Goneo SMTP: smtp.goneo.de · 465 SSL ODER 587 STARTTLS — Code wählt automatisch (secure=true bei 465).
SMTP_HOST=smtp.goneo.de
SMTP_PORT=465
SMTP_USER=neuerpartner@phoenix-maklerverbund.de
SMTP_PASS=
MAIL_FROM=neuerpartner@phoenix-maklerverbund.de
PHOENIX_NOTIFICATION_TO=info@phoenix-maklerverbund.de

# Public Base-URL der laufenden Site (für Trigger- und Foto-Upload-Links in den Mails).
APP_BASE_URL=https://phoenix.superbrand.marketing

# HMAC-Secret für signierte Onboarding-/Foto-Upload-Tokens. Pro Deploy einmal generieren:
# openssl rand -hex 32
TRIGGER_SECRET=
